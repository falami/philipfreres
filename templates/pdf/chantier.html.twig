<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <style>
    @page {
      margin: 18px 18px 35px 18px;
    }

    body {
      font-family: DejaVu Sans, sans-serif;
      font-size: 10px;
      color: #111;
    }

    .page-number:after {
      content: counter(page);
    }

    .footer {
      position: fixed;
      bottom: -22px;
      left: 0;
      right: 0;
      text-align: center;
      font-size: 9px;
      color: #333;
    }

    h1 {
      text-align: center;
      font-size: 18px;
      margin: 0 0 8px 0;
      text-transform: uppercase;
      border-bottom: 2px solid #111;
      padding-bottom: 6px;
    }

    h2 {
      font-size: 12px;
      margin: 12px 0 6px;
      background: #e9ecef;
      border: 1px solid #555;
      padding: 5px;
      text-transform: uppercase;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    .table-bordered td,
    .table-bordered th {
      border: 1px solid #555;
      padding: 5px;
      vertical-align: top;
    }

    .label {
      font-weight: bold;
    }

    .muted {
      color: #555;
    }

    .section-box {
      border: 1px solid #555;
      padding: 7px;
      min-height: 35px;
    }

    .two-cols td {
      width: 50%;
    }

    .photos-table {
      margin-top: 8px;
      page-break-inside: auto;
    }

    .photos-table th {
      background: #e9ecef;
      text-align: center;
      font-size: 11px;
    }

    .photo-cell {
      width: 50%;
      height: 255px;
      text-align: center;
      vertical-align: middle;
    }

    .photo-cell img {
      max-width: 100%;
      max-height: 235px;
      object-fit: contain;
    }

    .photo-date {
      font-weight: bold;
      font-size: 9px;
      text-align: right;
      border-top: 1px solid #555;
      padding-top: 3px;
    }

    .page-break {
      page-break-before: always;
    }

    .small {
      font-size: 9px;
    }
  </style>
</head>

<body>
<div class="footer">Page <span class="page-number"></span></div>

<h1>Compte rendu de chantier</h1>

<table class="table-bordered">
  <tr>
    <td style="width: 60%;">
      <span class="label">Chantier :</span><br>
      {{ chantier.nom }}
    </td>
    <td>
      <span class="label">Localisation :</span><br>
      {{ chantier.adresse ?: '' }}
      {% if chantier.codePostal or chantier.ville %}
        <br>{{ chantier.codePostal }} {{ chantier.ville }}
      {% endif %}
    </td>
  </tr>
</table>

<h2>Nature de la prestation</h2>
<div class="section-box">
  {{ chantier.naturePrestation|default('-')|nl2br }}
</div>

<h2>Planning</h2>
<table class="table-bordered">
  <tr>
    <td>
      <span class="label">Début traitement :</span>
      {{ chantier.dateDebutPrevisionnelle ? 'Semaine ' ~ chantier.dateDebutPrevisionnelle|date('W') : '-' }}
    </td>
    <td>
      <span class="label">Fin traitement :</span>
      {{ chantier.dateFinPrevisionnelle ? 'Semaine ' ~ chantier.dateFinPrevisionnelle|date('W') : '-' }}
    </td>
    <td>
      <span class="label">Durée prévisionnelle :</span>
      {{ chantier.dureePrevisionnelleJours ?: '-' }} j
    </td>
    <td>
      <span class="label">Durée réelle :</span>
      {{ chantier.dureeReelleJours ?: '-' }} j
    </td>
  </tr>
</table>

<h2>Moyens</h2>
<table class="table-bordered two-cols">
  <tr>
    <th>Humains</th>
    <th>Matériels / Engins</th>
  </tr>
  <tr>
    <td>
      {% for r in chantier.ressourcesHumaines %}
        - {{ r.utilisateur.prenom }} {{ r.utilisateur.nom }}
        {% if r.fonction %} — {{ r.fonction }}{% endif %}<br>
      {% else %}
        -
      {% endfor %}
    </td>
    <td>
      {% for r in chantier.ressourcesEngins %}
        - {{ r.engin.nom }}{% if r.commentaire %} — {{ r.commentaire }}{% endif %}<br>
      {% endfor %}

      {% for r in chantier.ressourcesMateriels %}
        - {{ r.materiel.nom }} × {{ r.quantite ?: 1 }}
        {% if r.commentaire %} — {{ r.commentaire }}{% endif %}<br>
      {% endfor %}

      {% if chantier.ressourcesEngins|length == 0 and chantier.ressourcesMateriels|length == 0 %}
        -
      {% endif %}
    </td>
  </tr>
</table>

<h2>Détail d'intervention</h2>
<table class="table-bordered">
  <tr>
    <td>
      <span class="label">Linéaire traité :</span>
      {{ chantier.lineaireTraite ?: '-' }}{% if chantier.lineaireTraite %} ml{% endif %}
    </td>
    <td>
      <span class="label">Surfaces traitées :</span>
      {{ chantier.surfaceTraitee ?: '-' }}{% if chantier.surfaceTraitee %} m²{% endif %}
    </td>
  </tr>
</table>

<h2>Difficultés rencontrées</h2>
<div class="section-box">
  {{ chantier.difficultesRencontrees|default('-')|nl2br }}
</div>

<h2>Bilan d'enlèvement d'encombrant ou autre déchets dans les ouvrages</h2>
<table class="table-bordered">
  <thead>
    <tr>
      <th>Type de déchet</th>
      <th>Poids total</th>
    </tr>
  </thead>
  <tbody>
    {% for d in chantier.dechets %}
      <tr>
        <td>{{ d.typeDechet.nom }}</td>
        <td>{{ d.poidsTotal ?: '0' }} {{ d.typeDechet.unite }}</td>
      </tr>
    {% else %}
      <tr>
        <td colspan="2">Aucun déchet renseigné</td>
      </tr>
    {% endfor %}
  </tbody>
</table>

<h2>Photos</h2>

{% for p in chantier.photos %}
  {% if loop.first == false %}
    <div style="height: 10px;"></div>
  {% endif %}

  <table class="table-bordered photos-table">
    <thead>
      <tr>
        <th>Avant</th>
        <th>Après</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td class="photo-cell">
          {% if p.photoAvant %}
            <img src="{{ absolute_url(asset('uploads/photos/chantiers/' ~ p.photoAvant)) }}" alt="Avant">
          {% endif %}
        </td>
        <td class="photo-cell">
          {% if p.photoApres %}
            <img src="{{ absolute_url(asset('uploads/photos/chantiers/' ~ p.photoApres)) }}" alt="Après">
          {% endif %}
        </td>
      </tr>
      <tr>
        <td>
          <span class="label">Date :</span>
          {{ p.datePriseVueAvant ? p.datePriseVueAvant|date('d/m/Y') : '' }}
        </td>
        <td class="photo-date">
          {{ p.datePriseVueApres ? p.datePriseVueApres|date('d/m/Y') : '' }}
        </td>
      </tr>
    </tbody>
  </table>
{% else %}
  <div class="section-box">Aucune photo renseignée.</div>
{% endfor %}

</body>
</html>