{% extends 'base_admin.html.twig' %}
{% set is_edit = modeEdition ?? false %}
{% block title %}{{ is_edit ? 'Modifier' : 'Ajouter' }} - Note{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/formulaire.css') }}">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};

      --bg:#f5f7fb;
      --panel:#fff;
      --ink:#0f172a;
      --muted:#64748b;
      --stroke: rgba(15, 23, 42, .10);
      --shadow: 0 18px 55px rgba(15, 23, 42, .10);
      --radius: 18px;
    }

    body{ background: var(--bg); }

    .hero{
      border-radius:22px;
      position:relative;
      overflow:hidden;
      color:#fff;
      box-shadow:0 18px 50px rgba(0,0,0,.14);
      background:
        radial-gradient(1200px 420px at 12% -10%, color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent), transparent 58%),
        radial-gradient(900px 380px at 92% 0%, color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent), transparent 60%),
        radial-gradient(700px 260px at 55% 115%, color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent), transparent 62%),
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    .accent{
      width: 12px;
      border-radius:999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      flex: 0 0 auto;
    }

    .chip{
      display:inline-flex;
      align-items:center;
      gap:.45rem;
      padding:.28rem .65rem;
      border-radius:999px;
      font-size:.82rem;
      background: rgba(255,255,255,.10);
      border:1px solid rgba(255,255,255,.14);
      color: rgba(255,255,255,.92);
      white-space: nowrap;
    }

    .chip i{ color: var(--theme-color-secondaire); }

    .cardx{
      background: var(--panel);
      border: 1px solid var(--stroke);
      border-radius: var(--radius);
      box-shadow: 0 10px 28px rgba(15,23,42,.08);
      overflow: visible;
    }

    .cardx-h{
      padding: .95rem 1.05rem;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:1rem;
      background: linear-gradient(180deg, rgba(0,0,0,.015), transparent);
      border-bottom: 1px solid var(--stroke);
    }

    .cardx-title{
      margin:0;
      font-weight:800;
      letter-spacing:-.01em;
      color: var(--ink);
      display:flex;
      align-items:center;
      gap:.6rem;
    }

    label.form-label{
      font-weight: 800;
      color: var(--ink);
    }

    .form-text,
    .text-muted,
    .small{
      color: var(--muted) !important;
    }

    .form-control,
    .form-select,
    textarea{
      border-radius: 14px;
      border: 1px solid var(--stroke);
      padding: .65rem .85rem;
      min-height: 44px;
    }

    .form-control:focus,
    .form-select:focus,
    textarea:focus{
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke));
      box-shadow: 0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
    }

    .btn-gradient{
      border:0;
      color:#0b1220;
      font-weight:900;
      background: linear-gradient(135deg,
        color-mix(in srgb, var(--theme-color-secondaire) 92%, #fff 8%),
        color-mix(in srgb, var(--theme-color-secondaire) 70%, var(--theme-color-tertiaire) 30%)
      );
      box-shadow: 0 16px 34px rgba(0,0,0,.16);
      border-radius: 14px;
      padding: .6rem .95rem;
    }

    /* ===== TomSelect ===== */
    .ts-wrapper{
      position: relative;
      z-index: 1;
    }

    .ts-wrapper.focus{
      z-index: 50;
    }

    .ts-wrapper .ts-control{
      border-radius: 14px !important;
      padding: .55rem .75rem !important;
      border-color: var(--stroke) !important;
      min-height: 44px;
      box-shadow: none !important;
    }

    .ts-wrapper.focus .ts-control{
      box-shadow: 0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent) !important;
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke)) !important;
    }

    .ts-wrapper.focus .ts-dropdown{
      z-index: 51 !important;
      width: 100% !important;
      min-width: 100% !important;
      max-width: 100% !important;
      box-sizing: border-box;
    }

    .ts-dropdown .ts-dropdown-content{
      max-height: 240px;
      overflow-y: auto;
    }

    /* ===== Champ date premium ===== */
    .datepickr-wrap{
      position: relative;
    }

    .datepickr-wrap .form-control{
      padding-right: 2.8rem;
      background-color: #fff;
      cursor: pointer;
    }

    .datepickr-wrap .datepickr-icon{
      position: absolute;
      top: 50%;
      right: .95rem;
      transform: translateY(-50%);
      color: var(--theme-color-principal);
      opacity: .8;
      pointer-events: none;
      font-size: 1rem;
    }

    .flatpickr-calendar{
      border: 1px solid var(--stroke);
      box-shadow: 0 18px 40px rgba(15,23,42,.15);
      border-radius: 16px;
      overflow: hidden;
    }

    /* ===== Input € premium ===== */
    .input-euro .form-control{
      border-top-right-radius: 0 !important;
      border-bottom-right-radius: 0 !important;
      text-align: end;
    }

    .input-euro .euro-suffix{
      border-top-left-radius: 0 !important;
      border-bottom-left-radius: 0 !important;
      min-width: 48px;
      justify-content: center;
      font-weight: 800;
      letter-spacing: .02em;
      color: var(--theme-color-principal);
      background: color-mix(in srgb, var(--theme-color-principal) 4%, #fff);
      border: 1px solid var(--stroke);
      border-left: 0;
    }

    .input-group.input-euro .form-control:focus{
      z-index: 3;
    }

    .input-group.input-euro .form-control:focus + .euro-suffix{
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke));
      box-shadow: 0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      position: relative;
      z-index: 2;
    }
  </style>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <script src="https://npmcdn.com/flatpickr/dist/l10n/fr.js"></script>
{% endblock %}

{% block body %}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>
    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-journal-plus me-2" style="color:var(--theme-color-secondaire)"></i>
            {{ is_edit ? 'Modifier' : 'Ajouter' }} une note manuelle
          </h2>
          <div class="opacity-75 mt-1">
            Entité : <b>{{ entite.nom }}</b>
            {% if is_edit %}
              - ID : <b>#{{ note.id }}</b>
            {% endif %}
          </div>

          <div class="d-flex gap-2 flex-wrap mt-3">
            <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
            <span class="chip"><i class="bi bi-pencil-square"></i> Saisie libre</span>
            <span class="chip"><i class="bi bi-clock"></i> {{ "now"|date("d/m/Y H:i") }}</span>
          </div>
        </div>

        <div class="d-flex gap-2">
          <a href="{{ path('app_administrateur_note_index', { entite: entite.id }) }}"
             class="btn btn-outline-light btn-sm fw-semibold">
            <i class="bi bi-arrow-left me-1"></i> Retour
          </a>
          <button type="submit" form="noteForm" class="btn btn-light btn-sm fw-semibold">
            <i class="bi bi-check me-1"></i> Enregistrer
          </button>
        </div>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  {{ form_start(form, { attr:{ id:'noteForm', novalidate:'novalidate' } }) }}
  {{ form_errors(form) }}

  <div class="row g-4">
    <div class="col-xl-8">
      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-card-text text-warning"></i> Contenu de la note</h5>
          <span class="chip">{{ is_edit ? 'Mode édition' : 'Mode création' }}</span>
        </div>
        <div class="p-3 p-md-4">
          <div class="row g-3">
            <div class="col-12 col-md-4">
              {{ form_label(form.dateTransaction) }}
              <div class="datepickr-wrap">
                {{ form_widget(form.dateTransaction, {
                  attr: {
                    class: 'form-control flatpickr-date',
                    placeholder: 'JJ/MM/AAAA',
                    autocomplete: 'off'
                  }
                }) }}
                <i class="bi bi-calendar3 datepickr-icon"></i>
              </div>
              {{ form_errors(form.dateTransaction) }}
            </div>

            <div class="col-12 col-md-8">{{ form_row(form.libelle) }}</div>
            <div class="col-12">{{ form_row(form.commentaire) }}</div>
          </div>
        </div>
      </div>

      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-cash-coin text-warning"></i> Montants</h5>
        </div>
        <div class="p-3 p-md-4">
          <div class="row g-3">
            <div class="col-12 col-md-4">{{ form_row(form.quantite) }}</div>

            <div class="col-12 col-md-4">
              {{ form_label(form.prixUnitaireEur) }}
              <div class="input-group input-euro">
                {{ form_widget(form.prixUnitaireEur, {
                  attr: {
                    class: 'form-control',
                    placeholder: '0,00',
                    inputmode: 'decimal'
                  }
                }) }}
                <span class="input-group-text euro-suffix">€</span>
              </div>
              {{ form_errors(form.prixUnitaireEur) }}
            </div>

            <div class="col-12 col-md-4">{{ form_row(form.tauxTvaPercent) }}</div>

            <div class="col-12 col-md-3">
              {{ form_label(form.montantRemiseEur) }}
              <div class="input-group input-euro">
                {{ form_widget(form.montantRemiseEur, {
                  attr: {
                    class: 'form-control',
                    placeholder: '0,00',
                    inputmode: 'decimal'
                  }
                }) }}
                <span class="input-group-text euro-suffix">€</span>
              </div>
              {{ form_errors(form.montantRemiseEur) }}
            </div>

            <div class="col-12 col-md-3">
              {{ form_label(form.montantHtEur) }}
              <div class="input-group input-euro">
                {{ form_widget(form.montantHtEur, {
                  attr: {
                    class: 'form-control',
                    placeholder: '0,00',
                    inputmode: 'decimal'
                  }
                }) }}
                <span class="input-group-text euro-suffix">€</span>
              </div>
              {{ form_errors(form.montantHtEur) }}
            </div>

            <div class="col-12 col-md-3">
              {{ form_label(form.montantTvaEur) }}
              <div class="input-group input-euro">
                {{ form_widget(form.montantTvaEur, {
                  attr: {
                    class: 'form-control',
                    placeholder: '0,00',
                    inputmode: 'decimal'
                  }
                }) }}
                <span class="input-group-text euro-suffix">€</span>
              </div>
              {{ form_errors(form.montantTvaEur) }}
            </div>

            <div class="col-12 col-md-3">
              {{ form_label(form.montantTtcEur) }}
              <div class="input-group input-euro">
                {{ form_widget(form.montantTtcEur, {
                  attr: {
                    class: 'form-control',
                    placeholder: '0,00',
                    inputmode: 'decimal'
                  }
                }) }}
                <span class="input-group-text euro-suffix">€</span>
              </div>
              {{ form_errors(form.montantTtcEur) }}
            </div>
          </div>

          <div class="form-text mt-2">
            Tu peux saisir uniquement le TTC, ou compléter tout le détail si besoin.
          </div>
        </div>
      </div>

      <div class="d-flex justify-content-end gap-2">
        <a href="{{ path('app_administrateur_note_index', { entite: entite.id }) }}" class="btn btn-secondary">
          <i class="bi bi-arrow-left"></i> Retour
        </a>
        <button type="submit" class="btn btn-gradient">
          <i class="bi bi-check"></i> {{ is_edit ? 'Enregistrer les modifications' : 'Créer la note' }}
        </button>
      </div>
    </div>

    <div class="col-xl-4">
      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-link-45deg text-warning"></i> Liaisons</h5>
        </div>
        <div class="p-3 p-md-4">
          <div class="row g-3">
            <div class="col-12">{{ form_row(form.engin) }}</div>
            <div class="col-12">{{ form_row(form.utilisateur) }}</div>
            <div class="col-12">{{ form_row(form.produit) }}</div>
          </div>
          <div class="small text-muted mt-2">
            Lie la note à un engin, un employé ou un produit pour faciliter les recherches.
          </div>
        </div>
      </div>
    </div>
  </div>

  {{ form_end(form) }}

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.js-tomselect').forEach((el) => {
        if (el.tomselect) return;

        new TomSelect(el, {
          create: false,
          allowEmptyOption: true,
          plugins: {
            clear_button: { title: 'Effacer' }
          }
        });
      });

      if (window.flatpickr?.l10ns?.fr) {
        flatpickr.localize(flatpickr.l10ns.fr);
      }

      document.querySelectorAll('.flatpickr-date').forEach((el) => {
        if (el._flatpickr) return;

        flatpickr(el, {
          dateFormat: 'd/m/Y',
          allowInput: true,
          disableMobile: true
        });
      });
    });
  </script>
{% endblock %}