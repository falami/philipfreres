<div class="btn-group user-actions" role="group">
  <a href="{{ path('app_administrateur_note_show', { entite: entite.id, id: note.id }) }}"
     class="btn btn-sm user-main"
     title="Voir">
    <i class="bi bi-eye"></i>
  </a>

  <button type="button"
          class="btn btn-sm dropdown-toggle dropdown-toggle-split user-split"
          data-bs-toggle="dropdown"
          aria-expanded="false">
    <span class="visually-hidden">Actions</span>
  </button>

  <ul class="dropdown-menu dropdown-menu-end user-menu">
    <li>
      <a class="dropdown-item" href="{{ path('app_administrateur_note_show', { entite: entite.id, id: note.id }) }}">
        <i class="bi bi-eye me-2"></i>Voir
      </a>
    </li>
    <li>
      <a class="dropdown-item" href="{{ path('app_administrateur_note_edit', { entite: entite.id, id: note.id }) }}">
        <i class="bi bi-pencil-square me-2"></i>Modifier
      </a>
    </li>
    <li><hr class="dropdown-divider"></li>
    <li>
      <button type="button"
              class="dropdown-item text-danger delete-btn"
              data-bs-toggle="modal"
              data-bs-target="#deleteModal"
              data-url="{{ path('app_administrateur_note_supprimer', { entite: entite.id, id: note.id }) }}"
              data-token="{{ csrf_token('delete_note_' ~ note.id) }}">
        <i class="bi bi-trash me-2"></i>Supprimer
      </button>
    </li>
  </ul>
</div>