{# templates/administrateur/produit/index.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Produit{% endblock %}

{% block stylesheets %}
  {{ parent() }}

  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.css"/>

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }

    /* ===== HERO (identique sessions) ===== */
    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;
      box-shadow: 0 18px 50px rgba(0,0,0,.14);

      background:
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }
    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }
    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }
    .chip{
      display:inline-flex; align-items:center; gap:.45rem;
      padding:.28rem .65rem; border-radius:999px; font-size:.82rem;
      background: rgba(255,255,255,.10);
      border:1px solid rgba(255,255,255,.14);
      color: rgba(255,255,255,.92);
      white-space: nowrap;
    }
    .chip i{ color: var(--theme-color-secondaire); }
    .hero .btn{ border-radius: 14px; font-weight: 800; }
    .hero .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }
    .hero .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    /* ===== Filterbar (identique sessions) ===== */
    .filterbar{
      background:#fff;
      border-radius:18px;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 10px 24px rgba(0,0,0,.05);
      overflow: visible;
    }
    .filterbar__top{
      padding: .9rem 1rem;
      border-bottom:1px solid rgba(0,0,0,.06);
      background: linear-gradient(180deg, rgba(0,0,0,.015), transparent);
      display:flex;
      align-items:center;
      gap:.75rem;
    }
    .filterbar__title{ font-weight:800; letter-spacing:-.01em; margin:0; font-size:1rem; }
    .filterbar__hint{ color: rgba(0,0,0,.55); font-size:.85rem; margin-left:.25rem; }
    .filterbar__body{ padding: 1rem; }

    .filtergrid{
      display:grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: .75rem;
      align-items:end;
    }

    .fcol-category{ grid-column: span 4; }
    .fcol-subcat  { grid-column: span 4; }
    .fcol-search  { grid-column: span 3; }
    .fcol-actions { grid-column: span 1; }

    @media (max-width: 1200px){
      .fcol-category{ grid-column: span 6; }
      .fcol-subcat  { grid-column: span 6; }
      .fcol-search  { grid-column: span 6; }
      .fcol-actions { grid-column: span 12; }
    }
    @media (max-width: 768px){
      .filterbar__body{ padding:.85rem; }
      .fcol-category, .fcol-subcat, .fcol-search, .fcol-actions{ grid-column: span 12; }
      .hero{ border-radius:16px; }
    }

    .filter-control .form-label{
      font-size:.78rem;
      font-weight:700;
      color: rgba(0,0,0,.55);
      text-transform:uppercase;
      letter-spacing:.06em;
      margin-bottom:.25rem;
    }
    .filterbox{
      border:1px solid rgba(0,0,0,.08);
      border-radius:14px;
      padding:.55rem .6rem;
      background:#fff;
      box-shadow: 0 8px 18px rgba(0,0,0,.04);
    }
    .filterbox:focus-within{
      border-color: rgba(255,193,7,.55);
      box-shadow: 0 0 0 .2rem rgba(255,193,7,.18), 0 10px 18px rgba(0,0,0,.06);
    }
    .filterrow{ display:flex; gap:.6rem; align-items:center; }

    .filter-icon{
      width:38px; height:38px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
      color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
      flex: 0 0 auto;
    }
    .filterbox .form-select,
    .filterbox .form-control{
      border:0 !important;
      box-shadow:none !important;
      padding-left:0 !important;
      padding-right:0 !important;
      background:transparent !important;
    }

    .resetbox{
      border:1px solid rgba(0,0,0,.08);
      border-radius:14px;
      padding:.55rem .6rem;
      background:#fff;
      box-shadow:0 8px 18px rgba(0,0,0,.04);
      cursor:pointer;
      user-select:none;
      transition: all .16s ease;
      width: 100%;
      display:flex;
      align-items:center;
      justify-content:center;
    }
    .resetbox:hover{
      border-color: rgba(0,0,0,.14);
      box-shadow: 0 10px 20px rgba(0,0,0,.06);
      transform: translateY(-1px);
    }
    .resetbox:focus,
    .resetbox:focus-visible{
      outline: none;
      border-color: rgba(255,193,7,.55);
      box-shadow: 0 0 0 .2rem rgba(255,193,7,.18), 0 10px 18px rgba(0,0,0,.06);
    }
    .resetbox.is-active{
      border-color: rgba(255,193,7,.35);
      background: rgba(255,193,7,.06);
    }
    .resetbox:disabled{ cursor: default; opacity: .55; transform:none; }
    .resetbox__text{ font-size:.9rem; font-weight:800; color: rgba(0,0,0,.65); }
    .resetbox__badge{
      min-width: 28px;
      height: 22px;
      padding: 0 .5rem;
      border-radius: 999px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      font-size:.78rem;
      font-weight:800;
      background: rgba(0,0,0,.06);
      color: rgba(0,0,0,.65);
      border: 1px solid rgba(0,0,0,.08);
      margin-left:.5rem;
    }
    .resetbox.is-active .resetbox__badge{
      background: rgba(255,193,7,.22);
      border-color: rgba(255,193,7,.30);
      color: rgba(0,0,0,.75);
    }

    .active-filters{
      padding: .65rem 1rem;
      border-top:1px solid rgba(0,0,0,.06);
      background:#fff;
      display:flex;
      align-items:center;
      gap:.5rem;
      flex-wrap:wrap;
    }
    .active-filters .label{
      font-size:.8rem;
      color: rgba(0,0,0,.55);
      font-weight:800;
      margin-right:.25rem;
    }
    .af-badge{
      display:inline-flex;
      align-items:center;
      gap:.35rem;
      border-radius:999px;
      padding:.35rem .6rem;
      border:1px solid rgba(0,0,0,.08);
      background: rgba(0,0,0,.03);
      font-size:.82rem;
      cursor:pointer;
      user-select:none;
    }
    .af-badge:hover{ background: rgba(255,193,7,.12); border-color: rgba(255,193,7,.25); }
    .af-badge i{ opacity:.7; }

    /* ===== Table card + DataTables (identique sessions) ===== */
    .table-card{
      background:#fff;
      border-radius:18px;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 12px 30px rgba(0,0,0,.06);
      overflow: visible;
    }
    table.dataTable{ margin:0 !important; }
    table.dataTable thead th{
      background:#f7f8fa!important;
      border-bottom:1px solid rgba(0,0,0,.08)!important;
      font-size:.78rem;
      text-transform:uppercase;
      letter-spacing:.05em;
      color: rgba(0,0,0,.55);
      text-align:center !important;
      vertical-align: middle;
    }
    #dtTypeDep tbody td{
      padding-top:.65rem!important;
      padding-bottom:.65rem!important;
      vertical-align: middle;
      text-align:center !important;
    }
    #dtTypeDep tbody tr:nth-child(even) > *{ background:rgba(35,51,66,.035)!important; }
    #dtTypeDep tbody tr:hover > *{ background:rgba(255,193,7,.08)!important; }

    #dtTypeDep_wrapper .dataTables_scrollBody{
      overflow-x:auto !important;
      -webkit-overflow-scrolling: touch;
      scrollbar-gutter: stable both-edges;
    }

    #dtTypeDep td.action-column{
      overflow: visible !important;
      white-space: nowrap !important;
      min-width: 160px;
      text-align:right !important;
    }

    @media (max-width: 768px){
      /* ✅ Colonne actions sticky à droite */
      #dtTypeDep td.action-column,
      #dtTypeDep th.action-column{
        position: sticky;
        right: 0;
        z-index: 5;
        background: #fff;
        box-shadow: -12px 0 18px -14px rgba(0,0,0,.22);
      }
      #dtTypeDep td.action-column{
        padding-left: .25rem !important;
        padding-right: .15rem !important;
      }
      /* Zebra/hovers sur sticky */
      #dtTypeDep tbody tr:nth-child(even) > td.action-column{
        background: rgba(35,51,66,.035) !important;
      }
      #dtTypeDep tbody tr:hover > td.action-column{
        background: rgba(255,193,7,.08) !important;
      }
    }

    /* ===== Actions (style "Devis"/Users) ===== */
    #dtTypeDep th:last-child,
    #dtTypeDep td:last-child{
      width: 1% !important;
      min-width: 0 !important;
      white-space: nowrap;
    }

    .type-actions .btn{ padding: .32rem .55rem; }

    .type-actions .type-main{
      background: rgba(255,255,255,.85);
      border-color: rgba(0,0,0,.12);
      box-shadow: 0 10px 22px rgba(0,0,0,.06);
    }
    .type-actions .type-main:hover{
      box-shadow: 0 14px 28px rgba(0,0,0,.10);
      border-color: rgba(0,0,0,.18);
    }
    .type-actions .type-split{
      padding-left: .55rem;
      padding-right: .55rem;
      border-color: rgba(0,0,0,.12);
      background: rgba(255,255,255,.85);
    }
    .type-actions .type-menu{
      border-radius: 16px;
      border: 1px solid rgba(0,0,0,.10);
      box-shadow: 0 18px 46px rgba(0,0,0,.18);
      padding: .55rem;
      background:
        radial-gradient(900px 220px at 10% 0%, rgba(255,193,7,.10), transparent 55%),
        #fff;
      overflow: hidden;
    }
    .type-actions .type-menu .dropdown-item{
      border-radius: 12px;
      padding: .50rem .60rem;
      margin: .10rem 0;
      border: 1px solid transparent;
    }
    .type-actions .type-menu .dropdown-item:hover{
      background: rgba(255,193,7,.10);
      border-color: rgba(255,193,7,.22);
    }

    .type-actions.btn-group .type-main{
      border-top-right-radius: 0 !important;
      border-bottom-right-radius: 0 !important;
    }
    .type-actions.btn-group .type-split{
      border-top-left-radius: 0 !important;
      border-bottom-left-radius: 0 !important;
      margin-left: -1px;
      position: relative;
    }
    .type-actions.btn-group .type-split:before{
      content:"";
      position:absolute;
      left:0;
      top:20%;
      bottom:20%;
      width:1px;
      background: rgba(0,0,0,.10);
    }

    body .type-floating-dropdown{ z-index: 20000 !important; }

  </style>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
  <script src="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.js"></script>
{% endblock %}

{% block body %}
  {# HERO #}
  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-tags me-2" style="color:var(--theme-color-secondaire)"></i>
            Catégories de produit
          </h2>

          <div class="opacity-75 mt-1">
            Catégories + sous-catégories + correspondances (ALX, Total & Edenred).
          </div>

          <div class="d-flex gap-2 flex-wrap mt-3">
            <span class="chip"><i class="bi bi-fuel-pump-fill"></i> Carburant</span>
            <span class="chip"><i class="bi bi-credit-card-2-front"></i> Mapping fournisseurs</span>
            <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
            <span class="chip"><i class="bi bi-clock-history"></i> <span id="hero-last-refresh">-</span></span>
          </div>
        </div>

        <div class="d-flex gap-2">
          <a class="btn btn-light btn-sm fw-semibold"
             href="{{ path('app_administrateur_produit_ajouter', { entite: entite.id }) }}">
            <i class="bi bi-plus-lg me-1"></i> Ajouter
          </a>

          <button type="button" class="btn btn-outline-light btn-sm fw-semibold"
                  onclick="document.getElementById('filtersCollapse')?.scrollIntoView({behavior:'smooth'})">
            <i class="bi bi-funnel me-1"></i> Filtres
          </button>
        </div>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  {# FILTERBAR #}
  <div class="filterbar mb-3">
    <div class="filterbar__top">
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <div class="filter-icon"><i class="bi bi-funnel"></i></div>
        <div>
          <div class="filterbar__title">Filtres</div>
          <div class="filterbar__hint">Affiner par catégorie, sous-catégorie, recherche…</div>
        </div>
      </div>

      <div class="ms-auto d-flex gap-2 align-items-center">
        <button class="btn btn-outline-secondary btn-sm fw-semibold d-md-none"
                type="button" data-bs-toggle="collapse" data-bs-target="#filtersCollapse">
          <i class="bi bi-sliders"></i> Filtres
        </button>

        <div class="dropdown">
          <button class="btn btn-warning btn-sm fw-semibold dropdown-toggle" data-bs-toggle="dropdown">
            <i class="bi bi-download"></i> Export
          </button>
          <ul class="dropdown-menu dropdown-menu-end" id="exportMenu"></ul>
        </div>
      </div>
    </div>

    <div class="collapse d-md-block" id="filtersCollapse">
      <div class="filterbar__body">
        <div class="filtergrid">

          <div class="filter-control fcol-category">
            <div class="form-label">Catégorie</div>
            <div class="filterbox">
              <div class="filterrow">
                <div class="filter-icon"><i class="bi bi-collection"></i></div>
                <select id="categorieFilter" class="form-select form-select-sm">
                  <option value="all">Toutes</option>
                  {# Optionnel: si tu passes categories depuis le controller #}
                  {% for c in categories|default([]) %}
                    <option value="{{ c }}">{{ c }}</option>
                  {% endfor %}
                </select>
              </div>
            </div>
          </div>

          <div class="filter-control fcol-subcat">
            <div class="form-label">Sous-catégorie</div>
            <div class="filterbox">
              <div class="filterrow">
                <div class="filter-icon"><i class="bi bi-diagram-3"></i></div>
                <select id="sousCategorieFilter" class="form-select form-select-sm">
                  <option value="all">Toutes</option>
                  {# Optionnel: si tu passes sousCategories depuis le controller #}
                  {% for sc in sousCategories|default([]) %}
                    <option value="{{ sc }}">{{ sc }}</option>
                  {% endfor %}
                </select>
              </div>
            </div>
          </div>

          <div class="filter-control fcol-search">
            <div class="form-label">Recherche</div>
            <div class="filterbox">
              <div class="filterrow">
                <div class="filter-icon"><i class="bi bi-search"></i></div>
                <input type="text" id="searchLibelle" class="form-control form-control-sm" placeholder="catégorie…" />
              </div>
            </div>
          </div>

          <div class="filter-control fcol-actions">
            <div class="form-label">&nbsp;</div>
            <button id="btnReset" type="button" class="resetbox" title="Réinitialiser les filtres">
              <i class="bi bi-arrow-counterclockwise me-2"></i>
              <span class="resetbox__text">Reset</span>
              <span class="resetbox__badge" id="resetCount" style="display:none;">0</span>
            </button>
          </div>

        </div>
      </div>

      <div class="active-filters" id="activeFilters">
        <span class="label"><i class="bi bi-lightning-charge"></i> Actifs :</span>
        <span class="text-muted small" id="activeFiltersEmpty">Aucun</span>
      </div>
    </div>
  </div>

  {# TABLE #}
  <div class="table-card mb-4 p-3">
    <table id="dtTypeDep" class="table table-hover align-middle mb-0 w-100">
      <thead>
        <tr>
          <th style="width:80px">#</th>
          <th>Sous-catégorie</th>
          <th>Catégorie</th>

          <th>ALX</th>
          <th>TOTAL</th>
          <th>EDENRED</th>

          <th class="action-column text-end" style="width:170px"></th>
        </tr>
      </thead>
      <tbody></tbody>
    </table>
  </div>

  <script>
  $(function(){
    const $cat    = $('#categorieFilter');
    const $subcat = $('#sousCategorieFilter');
    const $search = $('#searchLibelle');

    function nowLabel(){
      const d = new Date();
      return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
    }

    function escapeHtml(str){
      return String(str).replace(/[&<>"']/g, s => ({
        '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'
      }[s]));
    }

    function updateResetUi(count){
      const btn = document.getElementById('btnReset');
      const badge = document.getElementById('resetCount');
      if(!btn || !badge) return;

      if(count > 0){
        btn.disabled = false;
        btn.classList.add('is-active');
        badge.style.display = 'inline-flex';
        badge.textContent = String(count);
      } else {
        btn.disabled = true;
        btn.classList.remove('is-active');
        badge.style.display = 'none';
        badge.textContent = '0';
      }
    }

    function buildActiveFilters(){
      const items = [];

      const c = $cat.val();
      if(c && c !== 'all') items.push({ key:'cat', label:'Catégorie', value: $('#categorieFilter option:selected').text() });

      const sc = $subcat.val();
      if(sc && sc !== 'all') items.push({ key:'sub', label:'Sous-cat.', value: $('#sousCategorieFilter option:selected').text() });

      const s = ($search.val() || '').trim();
      if(s) items.push({ key:'search', label:'Recherche', value: s });

      const $wrap = $('#activeFilters');
      $wrap.find('.af-badge').remove();

      if(items.length === 0){
        $('#activeFiltersEmpty').show();
        updateResetUi(0);
        return;
      }

      $('#activeFiltersEmpty').hide();
      updateResetUi(items.length);

      items.forEach(it=>{
        const $b = $(`<span class="af-badge" data-key="${it.key}">
          <strong>${it.label} :</strong> ${escapeHtml(it.value)} <i class="bi bi-x-lg ms-1"></i>
        </span>`);

        $b.on('click', ()=>{
          switch(it.key){
            case 'cat':    $cat.val('all'); break;
            case 'sub':    $subcat.val('all'); break;
            case 'search': $search.val(''); break;
          }
          refreshAll(true);
        });

        $wrap.append($b);
      });
    }

    // ✅ Dropdown actions : flotter hors du scroll (anti-clipping)
    (function enableTypeActionsFloatingDropdown(){
      document.addEventListener('show.bs.dropdown', function(e){
        const toggle = e.target;
        if (!toggle.closest('.type-actions')) return;

        const dd = toggle.closest('.dropdown, .btn-group');
        if (!dd) return;

        const menu = dd.querySelector('.dropdown-menu');
        if (!menu) return;

        if (!menu.__originalParent) menu.__originalParent = dd;

        document.body.appendChild(menu);
        menu.classList.add('type-floating-dropdown');

        const rect = toggle.getBoundingClientRect();

        menu.style.position = 'absolute';
        menu.style.top = '0px';
        menu.style.left = '0px';
        menu.style.display = 'block';
        const menuRect = menu.getBoundingClientRect();

        const isEnd = menu.classList.contains('dropdown-menu-end') || menu.classList.contains('dropdown-menu-end');
        const top = rect.bottom + window.scrollY + 6;

        let left = isEnd
          ? (rect.right + window.scrollX - menuRect.width)
          : (rect.left + window.scrollX);

        left = Math.max(8, Math.min(left, window.scrollX + window.innerWidth - menuRect.width - 8));

        menu.style.top = `${top}px`;
        menu.style.left = `${left}px`;
      }, true);

      document.addEventListener('hidden.bs.dropdown', function(e){
        const toggle = e.target;
        if (!toggle.closest('.type-actions')) return;

        const dd = toggle.closest('.dropdown, .btn-group');
        if (!dd) return;

        document.querySelectorAll('body .type-floating-dropdown').forEach(menu => {
          if (menu.__originalParent === dd) {
            dd.appendChild(menu);
            menu.classList.remove('type-floating-dropdown');
            menu.style.position = '';
            menu.style.top = '';
            menu.style.left = '';
            menu.style.display = '';
          }
        });
      }, true);

      window.addEventListener('scroll', () => {
        document.querySelectorAll('.type-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
          .forEach(btn => btn.click());
      }, true);

      window.addEventListener('resize', () => {
        document.querySelectorAll('.type-actions [aria-expanded="true"][data-bs-toggle="dropdown"]')
          .forEach(btn => btn.click());
      }, true);
    })();

    const table = $('#dtTypeDep').DataTable({
      serverSide:true,
      processing:true,
      autoWidth: false,
      scrollX: true,
      scrollCollapse: true,
      responsive: false,

      ajax:{
        url:"{{ path('app_administrateur_produit_ajax', { entite: entite.id }) }}",
        type:"POST",
        data: d => {
          d.categorieFilter     = $cat.val() || 'all';
          d.sousCategorieFilter = $subcat.val() || 'all';
          d.searchLibelle       = $search.val() || '';
        }
      },

      dom:
        '<"dt-top d-flex flex-wrap gap-2 align-items-center justify-content-between"'
          + '<"dt-actions d-flex gap-2 align-items-center"B>'
          + '<"dt-search"f>'
        + '>'
        + 'rt'
        + '<"dt-bottom-internal d-flex flex-wrap gap-2 align-items-center justify-content-between"lip>',

      buttons:['copy','csv','excel','pdf','print'],
      lengthMenu:[[10,25,50,100],[10,25,50,100]],
      pageLength: 25,
      columns:[
        {data:'id', name:'id'},
        {data:'sousCategorie', name:'sousCategorie'},
        {data:'categorie', name:'categorie'},

        {
          data:'ext_alx',
          name:'ext_alx',
          orderable:false,
          searchable:false,
          render:(data, type)=>{
            if(type !== 'display') return Array.isArray(data) ? data.join(' | ') : (data || '');
            const arr = Array.isArray(data) ? data : (data ? [data] : []);
            if(!arr.length) return '<span class="text-muted">-</span>';

            return `<div class="d-flex flex-wrap gap-1 justify-content-center">
              ${arr.map(v => `<span class="badge rounded-pill bg-primary-subtle text-primary border border-primary-subtle">
                ${escapeHtml(v)}
              </span>`).join('')}
            </div>`;
          }
        },
        {
          data:'ext_total',
          name:'ext_total',
          orderable:false,
          searchable:false,
          render:(data, type)=>{
            if(type !== 'display') return Array.isArray(data) ? data.join(' | ') : (data || '');
            const arr = Array.isArray(data) ? data : (data ? [data] : []);
            if(!arr.length) return '<span class="text-muted">-</span>';

            return `<div class="d-flex flex-wrap gap-1 justify-content-center">
              ${arr.map(v => `<span class="badge rounded-pill bg-danger-subtle text-danger border border-danger-subtle">
                ${escapeHtml(v)}
              </span>`).join('')}
            </div>`;
          }
        },
        {
          data:'ext_edenred',
          name:'ext_edenred',
          orderable:false,
          searchable:false,
          render:(data, type)=>{
            if(type !== 'display') return Array.isArray(data) ? data.join(' | ') : (data || '');
            const arr = Array.isArray(data) ? data : (data ? [data] : []);
            if(!arr.length) return '<span class="text-muted">-</span>';

            return `<div class="d-flex flex-wrap gap-1 justify-content-center">
              ${arr.map(v => `<span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle">
                ${escapeHtml(v)}
              </span>`).join('')}
            </div>`;
          }
        },

        {data:'actions', name:'actions'}
      ],

      columnDefs:[
        // ✅ dernière colonne actions
        {targets:6, className:'action-column text-end', orderable:false, searchable:false},
        {targets:[0,1,2,3,4,5], className:'text-center'}
      ],

   

      order:[[0,'desc']],
      language:{ url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },

      initComplete:function(){
        const api = this.api();
        const $btns = $(api.buttons().container()).find('button');

        $('#exportMenu').empty();
        $btns.each(function(){
          const $b=$(this);
          $('<li><a class="dropdown-item" href="#">'+$b.text()+'</a></li>')
            .on('click',e=>{e.preventDefault();$b.click();})
            .appendTo('#exportMenu');
        });
        $(api.buttons().container()).hide();
        api.columns.adjust();
      }
    });

    function refreshAll(resetPaging=false){
      table.ajax.reload(null, !resetPaging ? false : true);
      buildActiveFilters();
      $('#hero-last-refresh').text('Maj : ' + nowLabel());
    }

    function dtAdjust(){ table.columns.adjust(); }
    table.on('init.dt', () => setTimeout(dtAdjust, 60));
    table.on('draw.dt', () => dtAdjust());
    window.addEventListener('resize', () => setTimeout(dtAdjust, 150));

    // listeners
    $cat.on('change',    ()=>refreshAll(true));
    $subcat.on('change', ()=>refreshAll(true));

    let tSearch=null;
    $search.on('input', ()=>{
      clearTimeout(tSearch);
      tSearch = setTimeout(()=>refreshAll(true), 300);
    });

    $('#btnReset').on('click', function(){
      $cat.val('all');
      $subcat.val('all');
      $search.val('');
      table.search('');
      refreshAll(true);
    });

    // init
    buildActiveFilters();
    $('#hero-last-refresh').text('Maj : ' + nowLabel());
  });
  </script>
{% endblock %}