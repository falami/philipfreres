{# templates/administrateur/produit/_actions.html.twig #}

<div class="btn-group btn-group-sm type-actions" role="group">

  {# ✅ Bouton principal = Modifier #}
  <a class="btn btn-light type-main"
     data-bs-toggle="tooltip" title="Modifier"
     href="{{ path('app_administrateur_produit_modifier', { entite: entite.id, id: t.id }) }}">
    <i class="bi bi-pencil"></i>
  </a>

  {# ✅ Split dropdown #}
  <button type="button"
          class="btn btn-light dropdown-toggle dropdown-toggle-split type-split"
          data-bs-toggle="dropdown"
          data-bs-auto-close="outside"
          aria-expanded="false">
    <span class="visually-hidden">Actions</span>
  </button>

  <ul class="dropdown-menu dropdown-menu-end type-menu">

    {# ✅ Afficher #}
    <li>
      <a class="dropdown-item d-flex align-items-center"
         href="{{ path('app_administrateur_produit_show', { entite: entite.id, id: t.id }) }}">
        <i class="bi bi-eye me-2"></i> Afficher
      </a>
    </li>

    {# ✅ Correspondances #}
    <li>
      <a class="dropdown-item d-flex align-items-center"
         href="{{ path('app_administrateur_produit_external_id_index', { entite: entite.id, produit: t.id }) }}">
        <i class="bi bi-link-45deg me-2"></i> Correspondances fournisseurs
      </a>
    </li>

    <li><hr class="dropdown-divider"></li>

    {# ✅ Supprimer (modal générique si tu l’as, sinon fallback confirm) #}
    <li>
      <button type="button"
              class="dropdown-item d-flex align-items-center text-danger delete-btn"
              {% if useDeleteModal|default(true) %}
                data-bs-toggle="modal" data-bs-target="#deleteModal"
                data-url="{{ path('app_administrateur_produit_supprimer', { entite: entite.id, id: t.id }) }}"
                data-token="{{ csrf_token('delete_produit_' ~ t.id) }}"
              {% else %}
                onclick="if(confirm('Supprimer ce type de dépense ?')){document.getElementById('delete-produit-{{ t.id }}').submit();}"
              {% endif %}>
        <i class="bi bi-trash me-2"></i> Supprimer
      </button>

      {# Form hidden (utilisé par deleteModal OU fallback confirm) #}
      <form id="delete-produit-{{ t.id }}"
            method="post"
            action="{{ path('app_administrateur_produit_supprimer', { entite: entite.id, id: t.id }) }}"
            class="d-none">
        <input type="hidden" name="_token" value="{{ csrf_token('delete_produit_' ~ t.id) }}">
      </form>
    </li>

  </ul>
</div>