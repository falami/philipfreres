{# templates/administrateur/carburant/_fuel_dashboard_css_block.html.twig #}
:root{
  --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
  --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
  --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
  --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};

  --bg:#f5f7fb;
  --panel:#ffffff;
  --ink:#0f172a;
  --muted:#64748b;
  --stroke: rgba(15, 23, 42, .10);
  --shadow: 0 18px 55px rgba(15, 23, 42, .10);
  --radius:18px;
}

/* ============================= */
/* PAGE BACKGROUND */
/* ============================= */

body{
  background: var(--bg);
  color: var(--ink);
}

/* ============================= */
/* HERO */
/* ============================= */

.hero{
  position:relative;
  border-radius: var(--radius);
  background: linear-gradient(
    135deg,
    var(--theme-color-principal),
    var(--theme-color-secondaire)
  );
  color:#fff;
  box-shadow: var(--shadow);
  overflow:hidden;
}

.hero .accent{
  position:absolute;
  left:0;
  top:0;
  bottom:0;
  width:6px;
  background: rgba(255,255,255,.35);
}

/* ============================= */
/* CHIP / BADGES */
/* ============================= */

.chip{
  display:inline-flex;
  align-items:center;
  gap:.5rem;
  padding:.4rem .75rem;
  border-radius:999px;
  font-size:.85rem;
  font-weight:600;
  background: rgba(255,255,255,.15);
  backdrop-filter: blur(6px);
  color:#fff;
}

.chip--pill{
  background: rgba(255,255,255,.25);
  font-weight:700;
}

.badge-soft{
  display:inline-flex;
  align-items:center;
  gap:.4rem;
  padding:.35rem .6rem;
  border-radius:12px;
  font-size:.8rem;
  font-weight:600;
  background: rgba(15,23,42,.06);
  color: var(--ink);
}

/* ============================= */
/* TOOLBAR */
/* ============================= */

.toolbar{
  background: var(--panel);
  border:1px solid var(--stroke);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding:1rem;
}

.filters-sticky{
  position:sticky;
  top:10px;
  z-index:20;
}

.chip-lib{
  display:flex;
  align-items:center;
  gap:.75rem;
}

.chip-lib-field{
  display:flex;
  align-items:center;
  gap:.4rem;
}

/* ============================= */
/* DROPDOWN LIST */
/* ============================= */

.dropdown-list{
  max-height:260px;
  overflow:auto;
  padding-right:.5rem;
}

.dropdown-item{
  cursor:pointer;
  font-size:.9rem;
}

/* ============================= */
/* PROVIDER CHIP */
/* ============================= */

.provider-chip{
  display:inline-flex;
  align-items:center;
  gap:.4rem;
  padding:.35rem .6rem;
  border-radius:14px;
  font-size:.75rem;
  font-weight:700;
  letter-spacing:.4px;
}

.provider-chip.alx{
  background:#0ea5e9;
  color:#fff;
}

.provider-chip.total{
  background:#ef4444;
  color:#fff;
}

.provider-chip.edenred{
  background:#6366f1;
  color:#fff;
}

/* ============================= */
/* CALENDAR */
/* ============================= */

.calendar-card{
  background: var(--panel);
  border:1px solid var(--stroke);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow:hidden;
}

.fc{
  font-family:inherit;
}

.fc-toolbar-title{
  font-weight:800;
}

.fc-button{
  border-radius:12px !important;
  border:1px solid var(--stroke) !important;
  background: var(--panel) !important;
  color: var(--ink) !important;
  font-weight:600;
  box-shadow:none !important;
}

.fc-button-primary:not(:disabled).fc-button-active,
.fc-button-primary:not(:disabled):active{
  background: var(--theme-color-principal) !important;
  color:#fff !important;
}

.fc-daygrid-day{
  transition: all .15s ease;
}

.fc-daygrid-day:hover{
  background: rgba(15,23,42,.03);
}

.fc-event{
  border-radius:10px !important;
  padding:.25rem .4rem !important;
  border:none !important;
  background: linear-gradient(
    135deg,
    var(--theme-color-principal),
    var(--theme-color-secondaire)
  ) !important;
  color:#fff !important;
  font-weight:700;
  font-size:.75rem;
  box-shadow: 0 6px 18px rgba(0,0,0,.15);
}

/* ============================= */
/* MODAL */
/* ============================= */

.modal-content{
  border:none;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
}

.modal-header{
  border:none;
}

.modal-body{
  background: var(--bg);
}

.table{
  font-size:.85rem;
}

.table thead th{
  font-weight:700;
  font-size:.8rem;
  color: var(--muted);
  border-bottom:1px solid var(--stroke);
}

.table tbody tr{
  transition: background .15s ease;
}

.table tbody tr:hover{
  background: rgba(15,23,42,.03);
}

/* ============================= */
/* MONEY */
/* ============================= */

.money{
  font-weight:700;
  letter-spacing:.3px;
}

/* ============================= */
/* MOBILE COLLAPSE */
/* ============================= */

.filters-mobile-toggle{
  display:flex;
  justify-content:space-between;
  align-items:center;
  background: var(--panel);
  border:1px solid var(--stroke);
  padding:.75rem 1rem;
  border-radius: var(--radius);
  font-weight:600;
  cursor:pointer;
}

.filters-mobile-body{
  transition: max-height .25s ease, opacity .25s ease;
}

@media (max-width:576px){

  .toolbar:not(.is-open) .filters-mobile-body{
    max-height:0;
    overflow:hidden;
    opacity:0;
  }

  .toolbar.is-open .filters-mobile-body{
    max-height:2000px;
    opacity:1;
  }

  .fc .fc-view-harness{
    min-height:70vh;
  }

  .hero{
    padding:1rem !important;
  }
}

/* ============================= */
/* SCROLLBAR CLEAN */
/* ============================= */

.dropdown-list::-webkit-scrollbar{
  width:6px;
}

.dropdown-list::-webkit-scrollbar-thumb{
  background: rgba(15,23,42,.15);
  border-radius:6px;
}








/* ===== TOOLBAR (like produit/index) ===== */
.toolbar{
  border-radius: 16px;
  background: #fff;
  border: 1px solid var(--stroke);
  box-shadow: 0 10px 24px rgba(0,0,0,.05);
  padding: .85rem;
}

/* icône carrée à gauche des chips (optionnel si tu veux) */
.filter-icon{
  width:38px; height:38px;
  border-radius:14px;
  display:grid; place-items:center;
  background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
  border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
  color: color-mix(in srgb, var(--theme-color-principal) 75%, #000 25%);
  flex: 0 0 auto;
}

/* chip style */
.toolbar .chip{
  display:inline-flex; align-items:center; gap:.5rem;
  padding:.35rem .7rem;
  border-radius:999px;
  background: rgba(0,0,0,.03);
  border: 1px solid rgba(0,0,0,.06);
  font-size:.85rem;
  color: rgba(0,0,0,.65);
}

/* ===== Dropdown premium (same as produit) ===== */
.toolbar .chip .dropdown-toggle{
  border-radius: 999px;
  border: 1px solid rgba(0,0,0,.10);
  background: rgba(255,255,255,.75);
  box-shadow: 0 8px 18px rgba(0,0,0,.06);
  color: rgba(0,0,0,.72);
  font-weight: 700;
  padding: .38rem .70rem;
  line-height: 1.1;
  transition: transform .08s ease, box-shadow .18s ease, border-color .18s ease;
}
.toolbar .chip .dropdown-toggle:hover{
  border-color: rgba(0,0,0,.16);
  box-shadow: 0 12px 22px rgba(0,0,0,.08);
}
.toolbar .chip .dropdown-toggle:active{ transform: translateY(1px); }

.toolbar .dropdown-menu{
  border-radius: 16px;
  border: 1px solid rgba(0,0,0,.10);
  box-shadow: 0 18px 46px rgba(0,0,0,.18);
  padding: .65rem;
  background:
    radial-gradient(900px 220px at 10% 0%, rgba(255,193,7,.10), transparent 55%),
    #fff;
  overflow: hidden;
}

.toolbar .dropdown-menu .form-control{
  border-radius: 999px;
  border: 1px solid rgba(0,0,0,.12);
  background: rgba(255,255,255,.95);
  padding: .42rem .85rem;
  box-shadow: none !important;
}
.toolbar .dropdown-menu .form-control:focus{
  border-color: rgba(255,193,7,.55);
  box-shadow: 0 0 0 .2rem rgba(255,193,7,.18) !important;
}

.toolbar .dropdown-menu .btn{
  border-radius: 999px;
  border: 1px solid rgba(0,0,0,.10);
  background: rgba(0,0,0,.03);
  font-weight: 700;
  padding: .35rem .7rem;
}
.toolbar .dropdown-menu .btn:hover{
  background: rgba(255,193,7,.12);
  border-color: rgba(255,193,7,.35);
}

.toolbar .dropdown-menu .dropdown-list{
  border-radius: 12px;
  border: 1px solid rgba(0,0,0,.06);
  background: rgba(255,255,255,.92);
  padding: .25rem;
  max-height: 280px;
  overflow: auto;
}

.toolbar .dropdown-menu .dropdown-item{
  border-radius: 12px;
  padding: .45rem .55rem;
  margin: .10rem 0;
  border: 1px solid transparent;
  background: transparent;
}
.toolbar .dropdown-menu .dropdown-item:hover{
  background: rgba(255,193,7,.10);
  border-color: rgba(255,193,7,.20);
}

.toolbar .dropdown-menu .form-check-input{
  width: 1.05rem;
  height: 1.05rem;
  border-radius: .35rem;
  border: 1px solid rgba(0,0,0,.18);
  margin-top: 0;
}
.toolbar .dropdown-menu .form-check-input:checked{
  background-color: var(--theme-color-secondaire);
  border-color: rgba(0,0,0,.10);
}

/* scrollbar clean */
.toolbar .dropdown-menu *::-webkit-scrollbar{ width: 10px; }
.toolbar .dropdown-menu *::-webkit-scrollbar-track{ background: rgba(0,0,0,.04); border-radius: 999px; }
.toolbar .dropdown-menu *::-webkit-scrollbar-thumb{ background: rgba(0,0,0,.18); border-radius: 999px; }
.toolbar .dropdown-menu *::-webkit-scrollbar-thumb:hover{ background: rgba(0,0,0,.26); }
.kpi .ico i{ color: var(--theme-color-secondaire); }




/* --- Libellé chip (desktop/tablette) --- */
.toolbar .chip.chip-lib{
  gap: .55rem;
}

.toolbar .chip-lib-title{
  display:inline-flex;
  align-items:center;
  gap:.45rem;
  font-weight: 900;
}

.toolbar .chip-lib-title .txt{
  opacity:.9;
}

.toolbar .chip-lib-field{
  display:inline-flex;
  align-items:center;
  gap:.45rem;
}

.toolbar .chip-lib-field #fLabel{
  width: 220px; /* desktop */
}

.toolbar .chip-lib-field #btnLabelClear{
  border-radius: 999px;
}


/* ===========================
   MOBILE ONLY - Filters collapse
   Ne change rien desktop/tablette
   =========================== */
@media (max-width: 576px){

  /* toolbar devient "collapsible" */
  .toolbar.filters-sticky{
    position: sticky;
    top: 0;
    z-index: 30;
  }

  /* header mobile (bouton) */
  .filters-mobile-toggle{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:.75rem;
    padding:.6rem .65rem;
    border-radius: 14px;
    border: 1px solid var(--stroke);
    background: rgba(255,255,255,.92);
    box-shadow: 0 10px 24px rgba(0,0,0,.06);
    cursor:pointer;
    user-select:none;
  }

  .filters-mobile-toggle .left{
    display:flex; align-items:center; gap:.6rem;
    font-weight: 900;
    color: var(--ink);
  }
  .filters-mobile-toggle .left i{
    color: var(--theme-color-secondaire);
    font-size: 1.05rem;
  }
  .filters-mobile-toggle .right{
    display:flex; align-items:center; gap:.5rem;
  }
  .filters-mobile-toggle .badge-soft{
    padding: .25rem .55rem;
    font-size: .75rem;
  }
  .filters-mobile-toggle .chev{
    transition: transform .18s ease;
    opacity:.85;
  }

  /* contenu repliable */
  .toolbar .filters-mobile-body{
    margin-top:.55rem;
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transform: translateY(-4px);
    transition: max-height .22s ease, opacity .18s ease, transform .18s ease;
  }

  /* état ouvert */
  .toolbar.is-open .filters-mobile-body{
    max-height: 900px; /* large pour contenir les chips */
    opacity: 1;
    transform: translateY(0);
  }
  .toolbar.is-open .filters-mobile-toggle .chev{
    transform: rotate(180deg);
  }

  /* sur mobile: chips plus compactes et passent en colonne */
  .toolbar .filters-mobile-body > .d-flex{
    flex-direction: column !important;
    align-items: stretch !important;
    gap: .55rem !important;
  }

  /* les chips prennent toute la largeur */
  .toolbar .filters-mobile-body .chip{
    width: 100%;
    justify-content: flex-start;
    flex-wrap: wrap;
  }

  /* inputs plus étroits automatiquement */
  #fLabel{ width: 100% !important; }

  /* actions bas */
  .toolbar .filters-mobile-body .filter-actions,
  .toolbar .filters-mobile-body .d-flex.gap-2.align-items-center{
    justify-content: space-between !important;
  }

  /* dropdown menus full width (confort mobile) */
  .toolbar .dropdown-menu{
    min-width: 100% !important;
  }

  @media (max-width: 576px){

  /* la chip Lib devient un mini-bloc */
  .toolbar .chip.chip-lib{
    display:flex;
    flex-direction: column;
    align-items: stretch;
    gap: .45rem;
    padding: .6rem .7rem; /* un peu + respirant */
  }

  /* ligne titre */
  .toolbar .chip-lib-title{
    display:flex;
    align-items:center;
    justify-content:flex-start;
    gap:.5rem;
  }

  /* ligne champ : input + bouton collés */
  .toolbar .chip-lib-field{
    display:flex;
    align-items: stretch;
    gap: 0; /* collé */
  }

  .toolbar .chip-lib-field #fLabel{
    width: 100% !important;
    border-top-right-radius: 0 !important;
    border-bottom-right-radius: 0 !important;
  }

  .toolbar .chip-lib-field #btnLabelClear{
    flex: 0 0 auto;
    border-left: 0;
    border-top-left-radius: 0 !important;
    border-bottom-left-radius: 0 !important;
    border-top-right-radius: 14px !important;
    border-bottom-right-radius: 14px !important;
    padding-left: .75rem;
    padding-right: .75rem;
  }

  /* optionnel : bouton un peu plus "soft" */
  .toolbar .chip-lib-field #btnLabelClear{
    background: rgba(0,0,0,.03);
    border-color: rgba(0,0,0,.12);
  }
}
}

/* TomSelect scope dans chip */
#fuelToolbar .ts-control{
  min-width: 240px;
  border-radius: 999px;
  padding: .25rem .6rem;
}
#fuelToolbar .ts-wrapper.single .ts-control{
  background: rgba(255,255,255,.85);
  border: 1px solid rgba(0,0,0,.10);
}
#fuelToolbar .ts-dropdown{
  border-radius: 14px;
  overflow: hidden;
}
@media (max-width:576px){
  #fuelToolbar .ts-control{ min-width: 100%; }
}



/* ✅ Chip scope : toujours sur 1 ligne (desktop inclus) */
.toolbar .chip.chip-scope{
  display:flex;
  align-items:center;
  gap:.5rem;
  flex-wrap: nowrap;         /* pas de retour à la ligne */
}

.toolbar .chip.chip-scope .chip-scope-text{
  white-space: nowrap;       /* texte sur 1 ligne */
  flex: 0 0 auto;            /* ne se fait pas écraser */
}

/* ✅ TomSelect dans la chip : ne “pousse” pas le texte */
.toolbar .chip.chip-scope .ts-wrapper{
  flex: 1 1 260px;           /* prend le reste, mais sans casser */
  min-width: 220px;          /* ajuste si tu veux plus petit */
}

.toolbar .chip.chip-scope .ts-control{
  white-space: nowrap;
}
