          <div class="kpi-top">
            <div class="d-flex align-items-center gap-2">
              <span class="ico"><i class="bi bi-receipt"></i></span>
              <div class="label">Ticket moyen</div>
            </div>
          </div>
          <div class="value" id="kpiAvg">-</div>
