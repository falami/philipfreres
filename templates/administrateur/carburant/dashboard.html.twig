  </div>



    {# Charts employés #}
  <div class="row g-4 mb-4">
    <div class="col-lg-6">
      <div class="cardx">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-people-fill text-warning"></i> Top employés (TTC)</h5>
          <span class="chip">Top</span>
        </div>
        <div class="p-3 p-md-4">
          <div class="chart-box sm"><canvas id="chEmp"></canvas></div>
          <div class="small text-muted mt-2">Montant TTC cumulé sur la période (filtrable).</div>
        </div>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="cardx">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-stack text-warning"></i> Dépenses par employé</h5>
          <span class="chip">Empilé</span>
        </div>
        <div class="p-3 p-md-4">
          <div class="chart-box sm"><canvas id="chEmpProvAmount"></canvas></div>
          <div class="small text-muted mt-2">Barres empilées TTC par fournisseur.</div>
        </div>
      </div>
    </div>

    <div class="col-lg-12">
      <div class="cardx">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-droplet-fill text-warning"></i> Quantités par employé</h5>
          <span class="chip">Empilé</span>
        </div>
        <div class="p-3 p-md-4">
          <div class="chart-box"><canvas id="chEmpProvQty"></canvas></div>
          <div class="small text-muted mt-2">Litres / unités (selon la source) - utile pour repérer les gros consommateurs.</div>
        </div>
      </div>
    </div>
  </div>

  {# Charts #}
  <div class="row g-4 mb-4">
    <div class="col-lg-12">
      <div class="cardx">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-activity text-warning"></i> Tendance mensuelle (TTC)</h5>
          <span class="chip">Analyse mensuelle</span>
        </div>
        <div class="p-3 p-md-4">
          <div class="chart-box"><canvas id="chTrend"></canvas></div>
        </div>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="cardx">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-pie-chart-fill text-warning"></i> Par fournisseur</h5>
          <span class="chip">Top</span>
        </div>
        <div class="p-3 p-md-4">
          <div class="chart-box sm"><canvas id="chProv"></canvas></div>
        </div>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="cardx">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-truck-front-fill text-warning"></i> Top engins</h5>
          <span class="chip">Top 10</span>
        </div>
        <div class="p-3 p-md-4">
          <div class="chart-box sm"><canvas id="chEng"></canvas></div>
        </div>
      </div>
    </div>
  </div>

  {# DataTable #}
  <div class="cardx mb-5">
    <div class="cardx-h">
      <h5 class="cardx-title"><i class="bi bi-table text-warning"></i> Transactions carburant</h5>
      <span class="chip">TOTAL, ALX, EDENRED & NOTE</span>
    </div>

    <div class="p-3 p-md-4">
      <div class="table-responsive">
        <table class="table table-hover align-middle w-100" id="dtFuel">
          <thead>
            <tr>
              <th>Date</th>
              <th>Fournisseur</th>
              <th>Engin</th>
              <th>Employé</th>
              <th>Libellé</th>
              <th>Catégorie</th>
              <th>Sous-catégorie</th>

              <th class="text-end">Quantité</th>
              <th class="text-end">Montant (TTC)</th>
            </tr>
          </thead>
          <tbody></tbody>
        </table>
      </div>
      <div class="small text-muted mt-2">Unification ALX/TOTAL/EDENRED/NOTE - filtre période + fournisseur + engin + employé.</div>
    </div>
  </div>

<script>
(function(){
  if (window.flatpickr && window.flatpickr.l10ns?.fr) flatpickr.localize(flatpickr.l10ns.fr);
    // =========================
    // AUTO RELOAD (FULL AUTO) - DOIT ÊTRE DÉFINI AVANT flatpickr/setDate
    // =========================
    var autoTimer = null;              // var => pas de TDZ
    var isRefreshing = false;
    var pendingRefresh = false;

    function scheduleRefresh(delay = 350){
      clearTimeout(autoTimer);
      autoTimer = setTimeout(() => runRefresh(), delay);
    }

    async function runRefresh(){
      if (isRefreshing) { pendingRefresh = true; return; }
      isRefreshing = true;

      try{
        await refresh();
      } finally {
        isRefreshing = false;
        if (pendingRefresh){
          pendingRefresh = false;
          scheduleRefresh(120);
        }
      }
    }

  const $start = document.getElementById('fStart');
  const $end   = document.getElementById('fEnd');
  const $range = document.getElementById('fRange');

  function isoLocal(d){
    const y = d.getFullYear();
    const m = String(d.getMonth()+1).padStart(2,'0');
    const day = String(d.getDate()).padStart(2,'0');
    return `${y}-${m}-${day}`;
  }
  function dateFromIso(isoStr){
    if (!isoStr) return null;
    const [y,m,d] = isoStr.split('-').map(Number);
    if (!y||!m||!d) return null;
    return new Date(y, m-1, d);
  }

  let fp = flatpickr($range, {
    locale: { ...flatpickr.l10ns.fr, rangeSeparator: " → " },
    mode: "range",
    dateFormat: "d/m/Y",
    allowInput: true,
    disableMobile: true,
    defaultDate: [dateFromIso($start.value), dateFromIso($end.value)].filter(Boolean),
    onChange: function(sd){
      const from = sd[0] ? isoLocal(sd[0]) : '';
      const to   = sd[1] ? isoLocal(sd[1]) : from;
      $start.value = from;
      $end.value = to;

      scheduleRefresh(250); // ✅ auto
    }
  });


  // ===== Quick Date Selector (année / trimestre / mois) =====
    // ===== Période type Dépenses (Année / Trimestre / Mois) =====
  const $periodType    = document.getElementById('periodType');
  const $periodYear    = document.getElementById('periodYear');
  const $periodQuarter = document.getElementById('periodQuarter');
  const $periodMonth   = document.getElementById('periodMonth');
  const $btnPeriodClear= document.getElementById('btnPeriodClear');

  function pad2(n){ return String(n).padStart(2,'0'); }

  function lastDayOfMonth(year, month1to12){
    return new Date(year, month1to12, 0).getDate();
  }

  function setRangeIso(isoStart, isoEnd){
    $start.value = isoStart;
    $end.value   = isoEnd;

    // synchro UI flatpickr + input
    fp.setDate([dateFromIso(isoStart), dateFromIso(isoEnd)], true);
  }
    // Auto refresh dès qu'on change la plage via setRangeIso()
  const _setRangeIso = setRangeIso;
  setRangeIso = function(isoStart, isoEnd){
    _setRangeIso(isoStart, isoEnd);
    scheduleRefresh(250);
  }

  function updatePeriodUi(){
    const t = $periodType.value;
    $periodQuarter.style.display = (t === 'quarter') ? '' : 'none';
    $periodMonth.style.display   = (t === 'month')   ? '' : 'none';
    $periodYear.style.display    = (t === 'all')     ? 'none' : '';
  }

  function applyPeriodToRange(){
    const t = $periodType.value;

    // Tout = "open range" => on remet la plage courante start/end serveur
    if (t === 'all') {
      setRangeIso("{{ start }}", "{{ end }}");
      return;
    }

    const y = parseInt($periodYear.value || '0', 10);
    if (!Number.isFinite(y) || y <= 0) return;

    if (t === 'year') {
      setRangeIso(`${y}-01-01`, `${y}-12-31`);
      return;
    }

    if (t === 'quarter') {
      const q = parseInt($periodQuarter.value || '0', 10);
      if (!Number.isFinite(q) || q < 1 || q > 4) return;

      const sm = (q - 1) * 3 + 1;
      const em = sm + 2;
      const endDay = pad2(lastDayOfMonth(y, em));

      setRangeIso(`${y}-${pad2(sm)}-01`, `${y}-${pad2(em)}-${endDay}`);
      return;
    }

    if (t === 'month') {
      const m = parseInt($periodMonth.value || '0', 10);
      if (!Number.isFinite(m) || m < 1 || m > 12) return;

      const endDay = pad2(lastDayOfMonth(y, m));
      setRangeIso(`${y}-${pad2(m)}-01`, `${y}-${pad2(m)}-${endDay}`);
      return;
    }
  }

  function initPeriodSelectors(){
    const now = new Date();
    const curY = now.getFullYear();
    const curM = now.getMonth() + 1;
    const curQ = Math.floor((curM - 1) / 3) + 1;

    // années: curY-4 .. curY+1 (comme ton ancien)
    $periodYear.innerHTML = '';
    for(let y = curY - 4; y <= curY + 1; y++){
      const opt = document.createElement('option');
      opt.value = String(y);
      opt.textContent = String(y);
      $periodYear.appendChild(opt);
    }
    $periodYear.value = String(curY);

    // mois
    $periodMonth.innerHTML = '';
    for(let m = 1; m <= 12; m++){
      const opt = document.createElement('option');
      opt.value = String(m);
      opt.textContent = pad2(m);
      $periodMonth.appendChild(opt);
    }
    $periodMonth.value = String(curM);

    // trimestre
    $periodQuarter.value = String(curQ);

    // ✅ défaut: année courante
    $periodType.value = 'year';
    updatePeriodUi();
    applyPeriodToRange();
  }

  initPeriodSelectors();

  // listeners
  $periodType?.addEventListener('change', () => {
    updatePeriodUi();
    applyPeriodToRange();
  });
  $periodYear?.addEventListener('change', applyPeriodToRange);
  $periodQuarter?.addEventListener('change', applyPeriodToRange);
  $periodMonth?.addEventListener('change', applyPeriodToRange);

  // clear -> revient à "année courante"
  $btnPeriodClear?.addEventListener('click', () => {
    initPeriodSelectors();
  });


  // TomSelect
  // TomSelect (safe)
  function initTomSelect(selector, options){
    const el = document.querySelector(selector);
    if (!el) return;
    if (el.tomselect) return; // déjà initialisé
    new TomSelect(el, options);
  }


  const money = (cents) => {
    const n = Number(cents||0)/100;
    try { return new Intl.NumberFormat('fr-FR',{style:'currency',currency:'EUR'}).format(n); }
    catch(e){ return n.toFixed(2).replace('.',',')+' €'; }
  };

  const numFR = (value, digits = 0) => {
    const n = Number(value || 0);
    try {
      return new Intl.NumberFormat('fr-FR', {
        minimumFractionDigits: digits,
        maximumFractionDigits: digits
      }).format(n);
    } catch (e) {
      // fallback
      return n.toFixed(digits).replace('.', ',');
    }
  };

  let chTrend=null, chProv=null, chEng=null, chEmp=null, chEmpProvAmount=null, chEmpProvQty=null;

  function ensureChart(ref, ctx, cfg){ if(ref) ref.destroy(); return new Chart(ctx, cfg); }



  function getChecked(selector){
    return Array.from(document.querySelectorAll(selector + ':checked'))
      .map(i => i.value)
      .filter(v => v !== null && v !== undefined && String(v).trim() !== '');
  }

  function setAll(selector, checked){
    document.querySelectorAll(selector).forEach((cb) => {
      // ne coche/décoche que si l'item est visible
      const item = cb.closest('label');
      const hidden = item?.classList.contains('d-none');
      if (!hidden) cb.checked = checked;
    });
  }

  function updateCounts(){
    const provAll = document.querySelectorAll('.fuel-filter-prov').length;
    const engAll  = document.querySelectorAll('.fuel-filter-engin').length;
    const empAll  = document.querySelectorAll('.fuel-filter-emp').length;
    const catAll  = document.querySelectorAll('.fuel-filter-cat').length;
    const sousAll = document.querySelectorAll('.fuel-filter-sous').length;

    const prov = getChecked('.fuel-filter-prov').length;
    const eng  = getChecked('.fuel-filter-engin').length;
    const emp  = getChecked('.fuel-filter-emp').length;
    const cat  = getChecked('.fuel-filter-cat').length;
    const sous = getChecked('.fuel-filter-sous').length;

    document.getElementById('provSelectedCount').textContent =
      (prov === 0) ? 'Aucun' : (prov === provAll ? 'Tous' : (prov + ' sel.'));

    document.getElementById('enginSelectedCount').textContent =
      (eng === 0) ? 'Aucun' : (eng === engAll ? 'Tous' : (eng + ' sel.'));

    document.getElementById('empSelectedCount').textContent =
      (emp === 0) ? 'Aucun' : (emp === empAll ? 'Tous' : (emp + ' sel.'));

    document.getElementById('catSelectedCount').textContent =
      (cat === 0) ? 'Aucun' : (cat === catAll ? 'Tous' : (cat + ' sel.'));

    document.getElementById('sousSelectedCount').textContent =
      (sous === 0) ? 'Aucun' : (sous === sousAll ? 'Tous' : (sous + ' sel.'));
  }

  function filterDropdown(listSelector, query){
    const q = (query || '').trim().toLowerCase();

    document.querySelectorAll(listSelector + ' label').forEach((item) => {
      const txt = (item.textContent || '').toLowerCase();
      const match = (q === '') || txt.includes(q);

      // show/hide
      item.classList.toggle('d-none', !match);

      // ✅ Excel-like : si ça ne matche pas -> on décoche
      if (!match) {
        const cb = item.querySelector('input[type="checkbox"]');
        if (cb && cb.checked) cb.checked = false;
      }
    });

    // ✅ met à jour les compteurs après filtrage/décochage
    updateCounts();
  }

  $(document).on('input', 'input[data-filter="prov"]', function(){
    filterDropdown('#provList', this.value);
  });

  $(document).on('input', 'input[data-filter="engin"]', function(){
    filterDropdown('#enginList', this.value);
  });

  $(document).on('input', 'input[data-filter="emp"]', function(){
    filterDropdown('#empList', this.value);
  });


  $(document).on('input', 'input[data-filter="cat"]', function(){
    filterDropdown('#catList', this.value);
    scheduleRefresh(350);
  });

  $(document).on('input', 'input[data-filter="sous"]', function(){
    filterDropdown('#sousList', this.value);
    scheduleRefresh(350);
  });

  // Tout/Aucun
  // Tout/Aucun (bootstrap dropdown) => empêcher fermeture + appliquer
  $(document).on('click', '[data-check-all="prov"]', function(e){
    e.preventDefault();
    e.stopPropagation();
    setAll('.fuel-filter-prov', true);
    updateCounts();
    scheduleRefresh(250);
  });
  $(document).on('click', '[data-uncheck-all="prov"]', function(e){
    e.preventDefault();
    e.stopPropagation();
    setAll('.fuel-filter-prov', false);
    updateCounts();
    scheduleRefresh(250);
  });

  $(document).on('click', '[data-check-all="engin"]', function(e){
    e.preventDefault(); e.stopPropagation();
    setAll('.fuel-filter-engin', true);
    updateCounts(); scheduleRefresh(250);
  });
  $(document).on('click', '[data-uncheck-all="engin"]', function(e){
    e.preventDefault(); e.stopPropagation();
    setAll('.fuel-filter-engin', false);
    updateCounts(); scheduleRefresh(250);
  });

  $(document).on('click', '[data-check-all="emp"]', function(e){
    e.preventDefault(); e.stopPropagation();
    setAll('.fuel-filter-emp', true);
    updateCounts(); scheduleRefresh(250);
  });
  $(document).on('click', '[data-uncheck-all="emp"]', function(e){
    e.preventDefault(); e.stopPropagation();
    setAll('.fuel-filter-emp', false);
    updateCounts(); scheduleRefresh(250);
  });

  $(document).on('click', '[data-check-all="cat"]', function(e){
    e.preventDefault(); e.stopPropagation();
    setAll('.fuel-filter-cat', true);
    updateCounts(); scheduleRefresh(250);
  });
  $(document).on('click', '[data-uncheck-all="cat"]', function(e){
    e.preventDefault(); e.stopPropagation();
    setAll('.fuel-filter-cat', false);
    updateCounts(); scheduleRefresh(250);
  });

  $(document).on('click', '[data-check-all="sous"]', function(e){
    e.preventDefault(); e.stopPropagation();
    setAll('.fuel-filter-sous', true);
    updateCounts(); scheduleRefresh(250);
  });
  $(document).on('click', '[data-uncheck-all="sous"]', function(e){
    e.preventDefault(); e.stopPropagation();
    setAll('.fuel-filter-sous', false);
    updateCounts(); scheduleRefresh(250);
  });

  // au changement d’une case → met à jour les compteurs
  $(document).on('change', '.fuel-filter-prov, .fuel-filter-engin, .fuel-filter-emp, .fuel-filter-cat, .fuel-filter-sous', function(){
    updateCounts();
    scheduleRefresh(250);
  });

  // init au chargement
  updateCounts();




  function getFilters(){
    const provAll = document.querySelectorAll('.fuel-filter-prov').length;
    const engAll  = document.querySelectorAll('.fuel-filter-engin').length;
    const empAll  = document.querySelectorAll('.fuel-filter-emp').length;
    const catAll  = document.querySelectorAll('.fuel-filter-cat').length;
    const sousAll = document.querySelectorAll('.fuel-filter-sous').length;

    const prov = getChecked('.fuel-filter-prov');

    // Engins
    const engRaw = getChecked('.fuel-filter-engin');
    const engNull = engRaw.includes('__NULL__');
    const engIds  = engRaw
      .filter(v => v !== '__NULL__')
      .map(v => parseInt(v,10))
      .filter(Number.isFinite);

    // Employés
    const empRaw = getChecked('.fuel-filter-emp');
    const empNull = empRaw.includes('__NULL__');
    const empIds  = empRaw
      .filter(v => v !== '__NULL__')
      .map(v => parseInt(v,10))
      .filter(Number.isFinite);

    // Catégories
    const catRaw  = getChecked('.fuel-filter-cat');
    const catNull = catRaw.includes('__NULL__');
    const catVals = catRaw.filter(v => v !== '__NULL__');

    // Sous-catégories
    const sousRaw  = getChecked('.fuel-filter-sous');
    const sousNull = sousRaw.includes('__NULL__');
    const sousVals = sousRaw.filter(v => v !== '__NULL__');

    const providersNone = (prov.length === 0);
    const providers = (prov.length === provAll) ? [] : prov;

    const enginNone = (engRaw.length === 0);
    const enginAllSelected = (engRaw.length === engAll);

    const employeNone = (empRaw.length === 0);
    const employeAllSelected = (empRaw.length === empAll);

    const categorieNone = (catRaw.length === 0);
    const categorieAllSelected = (catRaw.length === catAll);

    const sousCategorieNone = (sousRaw.length === 0);
    const sousCategorieAllSelected = (sousRaw.length === sousAll);

    return {
      dateStart: $start.value,
      dateEnd: $end.value,

      providersNone,
      providers,

      enginNone,
      enginIds: enginAllSelected ? [] : engIds,
      enginUncategorized: (!enginAllSelected && engNull) ? 1 : 0,

      employeNone,
      employeIds: employeAllSelected ? [] : empIds,
      employeUncategorized: (!employeAllSelected && empNull) ? 1 : 0,

      categorieNone,
      categorieProduits: categorieAllSelected ? [] : catVals,
      categorieUncategorized: (!categorieAllSelected && catNull) ? 1 : 0,

      sousCategorieNone,
      sousCategorieProduits: sousCategorieAllSelected ? [] : sousVals,
      sousUncategorized: (!sousCategorieAllSelected && sousNull) ? 1 : 0
    };
  }

  function qs(filters){
    const p = new URLSearchParams();
    p.set('dateStart', filters.dateStart);
    p.set('dateEnd', filters.dateEnd);

    if (filters.providersNone) p.set('providersNone', '1');
    if (filters.enginNone) p.set('enginNone', '1');
    if (filters.employeNone) p.set('employeNone', '1');
    if (filters.categorieNone) p.set('categorieNone', '1');
    if (filters.sousCategorieNone) p.set('sousCategorieNone', '1');
    if (filters.enginUncategorized) p.set('enginUncategorized', '1');
    if (filters.employeUncategorized) p.set('employeUncategorized', '1');
    if (filters.categorieUncategorized) p.set('categorieUncategorized', '1');
    if (filters.sousUncategorized) p.set('sousUncategorized', '1');

    (filters.providers||[]).forEach(v => p.append('providers[]', v));
    (filters.enginIds||[]).forEach(id => p.append('enginIds[]', String(id)));
    (filters.employeIds||[]).forEach(id => p.append('employeIds[]', String(id)));
    (filters.categorieProduits||[]).forEach(v => p.append('categorieProduits[]', v));
    (filters.sousCategorieProduits||[]).forEach(v => p.append('sousCategorieProduits[]', v));

    return p.toString();
  }

  async function loadSummary(){
    const url = "{{ path('app_administrateur_fuel_api_summary', {entite: entite.id}) }}?" + qs(getFilters());
    const r = await fetch(url, { headers: {'Accept':'application/json'} });
    if(!r.ok) throw new Error('Erreur dashboard carburant');
    return r.json();
  }

  function applyKpis(k){
    document.getElementById('kpiAmount').textContent = money(k.amount_cents);

    // ✅ quantité avec milliers + 2 décimales
    document.getElementById('kpiQty').textContent = numFR(k.qty || 0, 2);

    // ✅ compteur avec milliers
    document.getElementById('kpiCount').textContent = `${numFR(k.cnt || 0, 0)} transaction(s)`;

    // ✅ non rattachées avec milliers
    document.getElementById('kpiUnmatchedEngin').textContent = numFR(k.cnt_unmatched_engin || 0, 0);
    document.getElementById('kpiUnmatchedEmploye').textContent = `${numFR(k.cnt_unmatched_employe || 0, 0)} sans employé`;

    const avg = (k.cnt ? Math.round((k.amount_cents||0)/k.cnt) : 0);
    document.getElementById('kpiAvg').textContent = money(avg);
  }

  function applyCharts(c){
    const trendLabels = (c.trendMonthly||[]).map(x=>x.ym);
    const trendVals   = (c.trendMonthly||[]).map(x=>Number(x.amount_cents||0));

    chTrend = ensureChart(chTrend, document.getElementById('chTrend'), {
      type:'line',
      data:{ labels: trendLabels, datasets:[{ label:'Carburant TTC', data: trendVals }]},
      options:{
        responsive:true, maintainAspectRatio:false,
        plugins:{ legend:{position:'bottom'}, tooltip:{ callbacks:{ label:(ctx)=> money(ctx.parsed.y||0) } } },
        scales:{ y:{ ticks:{ callback:(v)=> money(v) } } }
      }
    });

    chProv = ensureChart(chProv, document.getElementById('chProv'), {
      type:'polarArea',
      data:{
        labels:(c.byProvider||[]).map(x=>x.label),
        datasets:[{ data:(c.byProvider||[]).map(x=>Number(x.v||0)) }]
      },
      options:{
        responsive:true, maintainAspectRatio:false,
        plugins:{ legend:{position:'bottom'}, tooltip:{ callbacks:{ label:(ctx)=> money(ctx.raw||0) } } }
      }
    });

    chEng = ensureChart(chEng, document.getElementById('chEng'), {
      type:'bar',
      data:{
        labels:(c.topEngins||[]).map(x=>x.label),
        datasets:[{ label:'Top engins TTC', data:(c.topEngins||[]).map(x=>Number(x.v||0)) }]
      },
      options:{
        responsive:true, maintainAspectRatio:false,
        plugins:{ legend:{display:false}, tooltip:{ callbacks:{ label:(ctx)=> money(ctx.parsed.y||0) } } },
        scales:{ y:{ ticks:{ callback:(v)=> money(v) } } }
      }
    });

        // ===== 1) Top employés (TTC) =====
    const empLabels = (c.byEmployee || []).map(x => x.label);
    const empVals   = (c.byEmployee || []).map(x => Number(x.v || 0));

    chEmp = ensureChart(chEmp, document.getElementById('chEmp'), {
      type: 'bar',
      data: { labels: empLabels, datasets: [{ label: 'TTC', data: empVals }] },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: { callbacks: { label: (ctx) => money(ctx.parsed.y || 0) } }
        },
        scales: { y: { ticks: { callback: (v) => money(v) } } }
      }
    });

    // ===== 2) Dépenses empilées par employé (ALX/TOTAL/EDENRED) =====
    const rowsA = (c.byEmployeeProviderAmount || []);
    const labelsA = rowsA.map(r => r.label);

    const dsAlxA = rowsA.map(r => Number(r.alx || 0));
    const dsTotA = rowsA.map(r => Number(r.total || 0));
    const dsEdeA = rowsA.map(r => Number(r.edenred || 0));
    const dsNotA = rowsA.map(r => Number(r.note || 0));

    chEmpProvAmount = ensureChart(chEmpProvAmount, document.getElementById('chEmpProvAmount'), {
      type: 'bar',
      data: {
        labels: labelsA,
        datasets: [
          { label: 'ALX', data: dsAlxA, stack: 'amount' },
          { label: 'TOTAL', data: dsTotA, stack: 'amount' },
          { label: 'EDENRED', data: dsEdeA, stack: 'amount' },
          { label: 'NOTE', data: dsNotA, stack: 'amount' },
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: { position: 'bottom' },
          tooltip: { callbacks: { label: (ctx) => `${ctx.dataset.label} : ${money(ctx.parsed.y || 0)}` } }
        },
        scales: {
          x: { stacked: true },
          y: { stacked: true, ticks: { callback: (v) => money(v) } }
        }
      }
    });

    // ===== 3) Quantités empilées par employé (ALX/TOTAL/EDENRED) =====
    const rowsQ = (c.byEmployeeProviderQty || []);
    const labelsQ = rowsQ.map(r => r.label);

    const dsAlxQ = rowsQ.map(r => Number(r.alx || 0));
    const dsTotQ = rowsQ.map(r => Number(r.total || 0));
    const dsEdeQ = rowsQ.map(r => Number(r.edenred || 0));
    const dsNotQ = rowsQ.map(r => Number(r.note || 0));

    chEmpProvQty = ensureChart(chEmpProvQty, document.getElementById('chEmpProvQty'), {
      type: 'bar',
      data: {
        labels: labelsQ,
        datasets: [
          { label: 'ALX', data: dsAlxQ, stack: 'qty' },
          { label: 'TOTAL', data: dsTotQ, stack: 'qty' },
          { label: 'EDENRED', data: dsEdeQ, stack: 'qty' },
          { label: 'NOTE', data: dsNotQ, stack: 'qty' },
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom' } },
        scales: {
          x: { stacked: true },
          y: { stacked: true }
        }
      }
    });
  }

  // DataTables
  let dt = null;

  function dtFilters(d){
    const f = getFilters();
    d.dateStart = f.dateStart;
    d.dateEnd = f.dateEnd;

    if (f.providersNone) d.providersNone = 1;
    if (f.enginNone) d.enginNone = 1;
    if (f.employeNone) d.employeNone = 1;
    if (f.categorieNone) d.categorieNone = 1;
    if (f.sousCategorieNone) d.sousCategorieNone = 1;
    if (f.enginUncategorized) d.enginUncategorized = 1;
    if (f.employeUncategorized) d.employeUncategorized = 1;
    if (f.categorieUncategorized) d.categorieUncategorized = 1;
    if (f.sousUncategorized) d.sousUncategorized = 1;

    (f.providers||[]).forEach(v => (d['providers[]'] ??= []).push(v));
    (f.enginIds||[]).forEach(v => (d['enginIds[]'] ??= []).push(v));
    (f.employeIds||[]).forEach(v => (d['employeIds[]'] ??= []).push(v));
    (f.categorieProduits||[]).forEach(v => (d['categorieProduits[]'] ??= []).push(v));
    (f.sousCategorieProduits||[]).forEach(v => (d['sousCategorieProduits[]'] ??= []).push(v));
  }


  function escapeHtml(str){
    return String(str ?? '').replace(/[&<>"']/g, s => ({
      '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'
    }[s]));
  }

  function providerChip(provider){
    const p = String(provider || '').toUpperCase();
    if(!p) return '<span class="text-muted">-</span>';

    const meta = {
      'ALX':     { cls:'alx',     icon:'bi-upc-scan' },
      'TOTAL':   { cls:'total',   icon:'bi-fuel-pump' },
      'EDENRED': { cls:'edenred', icon:'bi-credit-card' },
      'NOTE':  { cls:'note',  icon:'bi-pencil-square' },
    }[p] || { cls:'', icon:'bi-tag' };

    const label = escapeHtml(p);

    // ✅ data-copy pour copier au clic
    return `
      <span class="provider-chip ${meta.cls}" role="button" tabindex="0"
            data-copy="${label}" title="Cliquer pour copier">
        <i class="bi ${meta.icon}"></i> ${label}
      </span>`;
  }

  // ✅ click-to-copy (souris + clavier)
  $(document).on('click keydown', '[data-copy]', async function(e){
    if(e.type === 'keydown' && e.key !== 'Enter' && e.key !== ' ') return;
    e.preventDefault();

    const v = this.getAttribute('data-copy') || '';
    try{
      await navigator.clipboard.writeText(v);
    } catch(_) {
      // fallback si clipboard bloqué
      const ta = document.createElement('textarea');
      ta.value = v; document.body.appendChild(ta);
      ta.select(); document.execCommand('copy');
      document.body.removeChild(ta);
    }

    this.classList.add('is-copied');
    setTimeout(() => this.classList.remove('is-copied'), 450);
  });

  function initDt(){
    if (dt) return;
    dt = $('#dtFuel').DataTable({
      processing:true,
      serverSide:true,
      pageLength:25,
      lengthMenu:[[10,25,50,100],[10,25,50,100]],
      language:{ url:"https://cdn.datatables.net/plug-ins/1.13.8/i18n/fr-FR.json" },
      ajax:{
        url: "{{ path('app_administrateur_fuel_dt_transactions', {entite: entite.id}) }}",
        type:"GET",
        data: dtFilters
      },
      columns:[
        { data:'date' },
        { data:'provider', render:(d, t)=> (t === 'display' ? providerChip(d) : (d || '')) },
        { data:'engin', render:(d)=> d || '-' },
        { data:'employe', render:(d)=> d || '-' },
        { data:'label' },
        // ✅ NEW
        {
          data:'categorie',
          render:(d, type)=>{
            if(type !== 'display') return d || '';
            if(!d) return '<span class="text-muted">-</span>';
            return `<span class="badge-soft"><i class="bi bi-grid-3x3-gap me-1"></i>${escapeHtml(d)}</span>`;
          }
        },
        {
          data:'sousCategorie',
          render:(d, type)=>{
            if(type !== 'display') return d || '';
            if(!d) return '<span class="text-muted">-</span>';
            return `<span class="badge-soft"><i class="bi bi-diagram-3 me-1"></i>${escapeHtml(d)}</span>`;
          }
        },

        { data:'qty', className:'text-end',
          render:(d)=> `<span class="money">${numFR(d || 0, 2)}</span>`
        },
        { data:'amount_cents', className:'text-end',
          render:(d)=> `<span class="money">${money(d)}</span>`
        },
        
      ],
      order:[[0,'desc']]
    });
  }


  // ✅ Flatpickr : quand l'utilisateur change à la souris/clavier
  // (ajoute juste scheduleRefresh dans ton onChange existant)
  // -> tu modifies ton onChange flatpickr comme ci-dessous (voir section B)

  // ✅ Période (year/quarter/month)
  $periodType?.addEventListener('change', () => scheduleRefresh(200));
  $periodYear?.addEventListener('change', () => scheduleRefresh(200));
  $periodQuarter?.addEventListener('change', () => scheduleRefresh(200));
  $periodMonth?.addEventListener('change', () => scheduleRefresh(200));
  $btnPeriodClear?.addEventListener('click', () => scheduleRefresh(200));

  // ✅ Checkboxes
  $(document).on('change', '.fuel-filter-prov, .fuel-filter-engin, .fuel-filter-emp', function(){
    scheduleRefresh(250);
  });

  // ✅ Recherche dropdown (debounced)
  $(document).on('input', 'input[data-filter="prov"], input[data-filter="engin"], input[data-filter="emp"]', function(){
    scheduleRefresh(450);
  });

  // ✅ Boutons => forcent un refresh immédiat
  document.getElementById('btnRefreshTop')?.addEventListener('click', (e)=>{ e.preventDefault(); runRefresh(); });

  // ✅ Optionnel: tu peux carrément cacher Appliquer (si tu veux)
  // document.getElementById('btnApply')?.classList.add('d-none');

  async function refresh(){
    const btnRefresh = document.getElementById('btnRefreshTop');
    const btnReset   = document.getElementById('btnReset');

    try{
      btnRefresh && (btnRefresh.disabled = true);
      btnReset   && (btnReset.disabled = true);

      const data = await loadSummary();
      applyKpis(data.kpis);
      applyCharts(data.charts);

      initDt();
      dt?.ajax.reload(null,false);
    } finally {
      btnRefresh && (btnRefresh.disabled = false);
      btnReset   && (btnReset.disabled = false);
    }
  }


    document.getElementById('btnReset').addEventListener('click', () => {
      // dates
      $start.value = "{{ start }}";
      $end.value = "{{ end }}";
      fp.setDate([dateFromIso("{{ start }}"), dateFromIso("{{ end }}")], true);

      // tout coché
      setAll('.fuel-filter-prov', true);
      setAll('.fuel-filter-engin', true);
      setAll('.fuel-filter-emp', true);
      setAll('.fuel-filter-cat', true);
      setAll('.fuel-filter-sous', true);

      // clear search inputs
      $('input[data-filter]').val('').trigger('input');

      updateCounts();
      refresh();
    });



     const toolbar = document.getElementById('fuelToolbar');
    const btn = document.getElementById('btnFiltersMobile');
    const count = document.getElementById('filtersMobileCount');

    if(!toolbar || !btn || !count) return;

    // ✅ IMPORTANT: ne jamais fermer si on interagit avec un input/select/button dans la toolbar
    toolbar.addEventListener('click', function(e){
      // Ne rien faire : on ne bloque pas les events
    }, true);

    toolbar.addEventListener('keydown', function(e){
      // si on tape dans un champ => on bloque toute logique de toggle
      const isInteractive = e.target.closest('input, textarea, select');
    }, true);

    // afficher le bouton uniquement en mobile (CSS fait le reste, ici on force le display)
    function isMobile(){ return window.matchMedia && window.matchMedia('(max-width: 576px)').matches; }

    function updateMobileCount(){
      const prov = getChecked('.fuel-filter-prov').length;
      const eng  = getChecked('.fuel-filter-engin').length;
      const emp  = getChecked('.fuel-filter-emp').length;

      const catCount = getChecked('.fuel-filter-cat').length;
      const sousCount = getChecked('.fuel-filter-sous').length;
      const parts = [];
      if (prov) parts.push(`F: ${prov}`);
      if (eng)  parts.push(`Eng: ${eng}`);
      if (emp)  parts.push(`Emp: ${emp}`);
      if (catCount) parts.push(`Cat: ${catCount}`);
      if (sousCount) parts.push(`Ss: ${sousCount}`);

      count.textContent = parts.length ? parts.join(' · ') : 'Tous';

    }

    function hasFocusInside(){
      return !!toolbar.querySelector('input:focus, textarea:focus, select:focus');
    }

    // si un champ prend le focus en mobile => on force l'ouverture
    toolbar.addEventListener('focusin', () => {
      if (!isMobile()) return;
      toolbar.classList.add('is-open');
    });

    // si on sort du focus => on ne ferme pas automatiquement (on laisse l’utilisateur décider)
    toolbar.addEventListener('focusout', () => {
      // rien : volontaire
    });

    function syncBtnVisibility(){
      if (isMobile()){
        btn.classList.remove('d-none');
      } else {
        btn.classList.add('d-none');
        toolbar.classList.add('is-open'); // sur desktop, toujours "ouvert"
      }
    }

    function toggle(){
      if (!isMobile()) return;
      if (hasFocusInside()) return; // ✅ ne replie pas pendant la saisie
      toolbar.classList.toggle('is-open');
    }

    // état par défaut en mobile: fermé
    if (isMobile()) toolbar.classList.remove('is-open');
    else toolbar.classList.add('is-open');

    btn.addEventListener('click', toggle);
    btn.addEventListener('keydown', (e)=>{ if(e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); } });

    let wasMobile = isMobile();

    window.addEventListener('resize', () => {
      const nowMobile = isMobile();

      // ✅ les resize causés par le clavier (mobile->mobile) ne doivent rien fermer
      if (nowMobile === wasMobile) {
        syncBtnVisibility();
        return;
      }

      // ✅ on a vraiment changé de mode (breakpoint)
      wasMobile = nowMobile;
      syncBtnVisibility();

      if (nowMobile) {
        toolbar.classList.remove('is-open'); // mobile: fermé par défaut
      } else {
        toolbar.classList.add('is-open');    // desktop: ouvert
      }
    });

    // met à jour le badge quand les filtres changent
    $(document).on('change input',
      '.fuel-filter-prov, .fuel-filter-engin, .fuel-filter-emp, .fuel-filter-cat, .fuel-filter-sous',
      updateMobileCount
    );
    // init
    syncBtnVisibility();
    updateMobileCount();




  refresh();
})();

</script>
{% endblock %}