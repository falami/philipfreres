{% extends 'base_admin.html.twig' %}
{% block title %}Calendrier carburant - Par engin{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/formulaire.css') }}">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">
  <style>
    {{ include('administrateur/carburant/_fuel_dashboard_css_block.html.twig') }}
    .calendar-card{ background:var(--panel); border:1px solid var(--stroke); border-radius:var(--radius); box-shadow: var(--shadow); overflow:hidden; }
    #calendar{ padding: 0 !important; }
    .fc .fc-view-harness{ min-height: 72vh; }
  </style>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <script src="https://npmcdn.com/flatpickr/dist/l10n/fr.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/fullcalendar/index.global.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@fullcalendar/core@6.1.20/locales/fr.global.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
{% endblock %}

{% block body %}
  {% set pageTitle = 'Calendrier des dépense par engin' %}
  {% set pageSubtitle = 'Choisis un engin (scope) pour limiter l’affichage. Les filtres multi restent actifs.' %}
  {% set activeTab = 'engin' %}

  {% include 'administrateur/carburant/_calendar_common.html.twig' %}
  {% include 'administrateur/carburant/_calendar_js.html.twig' with { mode: 'engin' } %}
{% endblock %}