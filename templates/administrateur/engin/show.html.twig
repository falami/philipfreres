{# templates/administrateur/engin/show.html.twig #}
{% extends 'base_admin.html.twig' %}

{% block title %}Engin #{{ engin.id }} - {{ engin.nom }}{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000')) }};
      --stroke: rgba(15,23,42,.10);
      --radius: 18px;
    }
    .cardx{background:#fff;border:1px solid var(--stroke);border-radius:var(--radius);box-shadow:0 10px 28px rgba(15,23,42,.08);overflow:hidden}
    .cardx-h{padding:.95rem 1.05rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;background:linear-gradient(180deg,rgba(0,0,0,.015),transparent);border-bottom:1px solid var(--stroke)}
    .cardx-title{margin:0;font-weight:800;letter-spacing:-.01em;display:flex;align-items:center;gap:.6rem}
    .hero{border-radius:22px;position:relative;overflow:hidden;color:#fff;box-shadow:0 18px 50px rgba(0,0,0,.14);
      background:
        radial-gradient(900px 380px at 92% 0%, color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent), transparent 60%),
        linear-gradient(135deg, color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%), color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%));
    }
    .cover{
      width:100%; height: 220px; border-radius:18px;
      border:1px solid rgba(255,255,255,.18);
      overflow:hidden;
      background: rgba(255,255,255,.10);
    }
    .cover img{width:100%;height:100%;object-fit:cover}
    .chip{display:inline-flex;align-items:center;gap:.45rem;padding:.28rem .65rem;border-radius:999px;font-size:.82rem;background:rgba(255,255,255,.10);border:1px solid rgba(255,255,255,.14);color:rgba(255,255,255,.92);white-space:nowrap}
    .chip i{color:var(--theme-color-secondaire)}
  </style>
{% endblock %}

{% block body %}
  <div class="hero p-3 mb-4">
    <div class="d-flex justify-content-between gap-3 flex-wrap">
      <div>
        <h2 class="m-0 fw-bold">
          <i class="bi bi-truck-front-fill me-2" style="color:var(--theme-color-secondaire)"></i>
          {{ engin.nom }}
        </h2>
        <div class="opacity-75 mt-1">
          {{ engin.type ? engin.type.value : '-' }}
          {% if engin.immatriculation %} • {{ engin.immatriculation }}{% endif %}
        </div>

        <div class="d-flex gap-2 flex-wrap mt-3">
          <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
          <span class="chip"><i class="bi bi-hash"></i> #{{ engin.id }}</span>
          <span class="chip"><i class="bi bi-calendar3"></i> {{ engin.annee ?: '-' }}</span>
        </div>
      </div>

      <div class="d-flex gap-2 align-items-start">
        <a href="{{ path('app_administrateur_engin_index',{entite:entite.id}) }}" class="btn btn-outline-light btn-sm fw-semibold">
          <i class="bi bi-arrow-left me-1"></i> Retour
        </a>
        <a href="{{ path('app_administrateur_engin_modifier',{entite:entite.id,id:engin.id}) }}" class="btn btn-light btn-sm fw-semibold">
          <i class="bi bi-pencil me-1"></i> Modifier
        </a>
        <form method="post"
              action="{{ path('app_administrateur_engin_supprimer',{entite:entite.id,id:engin.id}) }}"
              onsubmit="return confirm('Supprimer cet engin ?');">
          <input type="hidden" name="_token" value="{{ csrf_token('delete_engin_' ~ engin.id) }}">
          <button class="btn btn-danger btn-sm fw-semibold" type="submit">
            <i class="bi bi-trash me-1"></i> Supprimer
          </button>
        </form>
      </div>
    </div>

    {% if engin.photoCouverture %}
      <div class="mt-3 cover">
        <img src="{{ asset('uploads/photos/engin/' ~ engin.photoCouverture) }}" alt="Couverture">
      </div>
    {% endif %}
  </div>

  {% include 'flagMessage.html.twig' %}

  <div class="row g-4">
    <div class="col-lg-7">
      <div class="cardx">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-info-circle text-warning"></i> Détails</h5>
        </div>
        <div class="p-3 p-md-4">
          <div class="row g-3">
            <div class="col-md-6">
              <div class="text-muted small">Immatriculation</div>
              <div class="fw-semibold">{{ engin.immatriculation ?: '-' }}</div>
            </div>
            <div class="col-md-6">
              <div class="text-muted small">Créé le</div>
              <div class="fw-semibold">{{ engin.dateCreation ? engin.dateCreation|date('d/m/Y') : '-' }}</div>
            </div>
            <div class="col-md-6">
              <div class="text-muted small">Type</div>
              <div class="fw-semibold">{{ engin.type ? engin.type.value : '-' }}</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="cardx">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-link-45deg text-warning"></i> Identifiants externes</h5>
        </div>
        <div class="p-3 p-md-4">
          {% if engin.externalIds is defined and engin.externalIds|length > 0 %}
            <div class="vstack gap-2">
              {% for xid in engin.externalIds %}
                <div class="d-flex justify-content-between align-items-center border rounded-4 p-2">
                  <div>
                    <div class="fw-semibold">{{ xid.provider ? xid.provider.name : '-' }}</div>
                    <div class="text-muted small">{{ xid.value }}</div>
                    {% if xid.note %}<div class="text-muted small mt-1">{{ xid.note }}</div>{% endif %}
                  </div>
                  <span class="badge text-bg-light">ID</span>
                </div>
              {% endfor %}
            </div>
          {% else %}
            <div class="text-muted">Aucun identifiant externe.</div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
{% endblock %}