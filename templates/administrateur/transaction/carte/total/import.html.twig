{# templates/administrateur/transaction/carte/total/import.html.twig #}
{% extends 'base_admin.html.twig' %}

{% block title %}Import transactions carte{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/formulaire.css') }}">
  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000')) }};
      --bg:#f5f7fb; --panel:#fff; --ink:#0f172a; --muted:#64748b;
      --stroke: rgba(15, 23, 42, .10);
      --radius: 18px;
      --shadow: 0 18px 55px rgba(15, 23, 42, .10);
    }
    body{ background:var(--bg); }
    .hero{
      border-radius:22px; padding:1.2rem; position:relative; overflow:hidden; color:#fff;
      box-shadow:0 18px 50px rgba(0,0,0,.14);
      background:
        radial-gradient(900px 380px at 92% 0%, color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent), transparent 60%),
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }
    .hero::after{ content:""; position:absolute; inset:0; background:linear-gradient(180deg, rgba(255,255,255,.12), rgba(255,255,255,0) 55%); opacity:.85; pointer-events:none; }
    .accent{ width:12px; border-radius:999px; background:var(--theme-color-secondaire); box-shadow:0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent); }
    .chip{ display:inline-flex; align-items:center; gap:.45rem; padding:.28rem .65rem; border-radius:999px; font-size:.82rem;
      background:rgba(255,255,255,.10); border:1px solid rgba(255,255,255,.14); color:rgba(255,255,255,.92); white-space:nowrap; }
    .chip i{ color:var(--theme-color-secondaire); }
    .cardx{ background:var(--panel); border:1px solid var(--stroke); border-radius:var(--radius); box-shadow:0 10px 28px rgba(15,23,42,.08); overflow:hidden; }
    .cardx-h{ padding:.95rem 1.05rem; display:flex; align-items:center; justify-content:space-between; gap:1rem;
      background:linear-gradient(180deg, rgba(0,0,0,.015), transparent); border-bottom:1px solid var(--stroke); }
    .cardx-title{ margin:0; font-weight:800; letter-spacing:-.01em; color:var(--ink); display:flex; align-items:center; gap:.6rem; }
    label.form-label{ font-weight:700; color:var(--ink); }
    .form-text, .text-muted, .small{ color:var(--muted) !important; }
    .form-control{ border-radius:14px; border:1px solid var(--stroke); padding:.65rem .85rem; min-height:44px; }
    .form-control:focus{ border-color:color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke));
      box-shadow:0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent); }
  </style>
{% endblock %}

{% block body %}

  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>
    <div class="flex-grow-1">
      <h2 class="m-0 fw-bold">
        <i class="bi bi-file-earmark-excel me-2" style="color:var(--theme-color-secondaire)"></i>
        Import Excel - Transactions carte
      </h2>
      <div class="opacity-75 mt-1">Import robuste : détection d’entêtes, parsing dates/heures, anti-doublons.</div>
      <div class="d-flex gap-2 flex-wrap mt-3">
        <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
        <span class="chip"><i class="bi bi-shield-check"></i> Admin</span>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  <div class="cardx">
    <div class="cardx-h">
      <h5 class="cardx-title"><i class="bi bi-upload text-warning"></i> Fichier à importer</h5>
      <span class="chip">.xlsx / .xls</span>
    </div>
    <div class="p-3 p-md-4">
      {{ form_start(form, {attr:{novalidate:'novalidate'}}) }}
        {{ form_row(form.file) }}
        <div class="form-text mt-2">
          Astuce : même s’il y a des lignes au-dessus, l’import cherchera automatiquement la ligne d’entêtes.
        </div>

        <div class="d-flex justify-content-end gap-2 mt-3">
          <a href="{{ path('app_administrateur_utilisateur_index', {entite: entite.id}) }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Retour
          </a>
          <button class="btn btn-gradient" type="submit">
            <i class="bi bi-play-fill"></i> Lancer l’import
          </button>
        </div>
      {{ form_end(form) }}
    </div>
  </div>

{% endblock %}