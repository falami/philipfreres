{# templates/administrateur/transaction/carte/alx/index.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}Transactions Carte ALX{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/style-table.css') }}">
  <link rel="stylesheet" href="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.css"/>

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};
    }
    .hero{ border-radius:22px; position:relative; overflow:hidden; color:#fff; box-shadow:0 18px 50px rgba(0,0,0,.14);
      background:
        radial-gradient(900px 380px at 92% 0%, color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent), transparent 60%),
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }
    .hero .accent{width:12px; border-radius:999px; background:var(--theme-color-secondaire);
      box-shadow:0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);}
    .hero .chip{display:inline-flex; align-items:center; gap:.5rem; padding:.32rem .7rem; border-radius:999px;
      background:rgba(255,255,255,.10); border:1px solid rgba(255,255,255,.14); font-size:.82rem; color:rgba(255,255,255,.92);
      backdrop-filter: blur(6px); white-space:nowrap;}
    table.dataTable thead th{white-space:nowrap;}
    @media (max-width:768px){
      td.action-column{ position:sticky; right:0; background:#fff; box-shadow:-12px 0 18px -14px rgba(0,0,0,.22); z-index:5; }
    }
    .table-card{background:#fff; border-radius:18px; border:1px solid rgba(0,0,0,.06); box-shadow:0 12px 30px rgba(0,0,0,.06); overflow:hidden;}

    /* actions (même design que utilisateur / engin) */
    .user-actions .btn{ padding: .32rem .55rem; }
    .user-actions .user-main{
      background: rgba(255,255,255,.85);
      border-color: rgba(0,0,0,.12);
      box-shadow: 0 10px 22px rgba(0,0,0,.06);
    }
    .user-actions .user-split{
      padding-left:.55rem; padding-right:.55rem;
      border-color: rgba(0,0,0,.12);
      background: rgba(255,255,255,.85);
    }
    .user-actions .user-menu{
      border-radius: 16px;
      border: 1px solid rgba(0,0,0,.10);
      box-shadow: 0 18px 46px rgba(0,0,0,.18);
      padding: .55rem;
      background: radial-gradient(900px 220px at 10% 0%, rgba(255,193,7,.10), transparent 55%), #fff;
      overflow: hidden;
    }
    .user-actions .user-menu .dropdown-item{
      border-radius: 12px; padding:.50rem .60rem; margin:.10rem 0;
      border: 1px solid transparent;
    }
    .user-actions .user-menu .dropdown-item:hover{
      background: rgba(255,193,7,.10);
      border-color: rgba(255,193,7,.22);
    }
    .user-actions.btn-group .user-main{
      border-top-right-radius:0!important; border-bottom-right-radius:0!important;
    }
    .user-actions.btn-group .user-split{
      border-top-left-radius:0!important; border-bottom-left-radius:0!important;
      margin-left:-1px; position:relative;
    }
    .user-actions.btn-group .user-split:before{
      content:""; position:absolute; left:0; top:20%; bottom:20%; width:1px; background: rgba(0,0,0,.10);
    }

    /* si DataTables scrollX clippe le dropdown */
    .dropdown-menu.dropdown-menu-floating{
      z-index: 2000 !important;
    }




    /* TOOLBAR Export (comme TOTAL) */
    .filterbar{
      background:#fff;
      border-radius:18px;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 10px 24px rgba(0,0,0,.05);
      overflow-x:clip;
    }
    .filterbar__top{
      padding:.9rem 1rem;
      border-bottom:1px solid rgba(0,0,0,.06);
      background: linear-gradient(180deg, rgba(0,0,0,.015), transparent);
      display:flex;
      align-items:center;
      gap:.75rem;
    }
    .filter-icon{
      width:38px; height:38px;
      border-radius:14px;
      display:grid; place-items:center;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
    }
    
  </style>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
  <script src="https://cdn.datatables.net/v/bs5/dt-2.2.2/b-3.0.2/b-html5-3.0.2/b-print-3.0.2/datatables.min.js"></script>
{% endblock %}

{% block body %}

  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>
    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-fuel-pump me-2" style="color:var(--theme-color-secondaire)"></i>
            Transactions Carte ALX
          </h2>
          <div class="opacity-75 mt-1">Consultation des lignes importées depuis Excel.</div>
          <div class="d-flex flex-wrap gap-2 mt-3">
            <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
            <span class="chip"><i class="bi bi-clock-history"></i> <span id="hero-last-refresh">-</span></span>
          </div>
        </div>

        <div class="d-flex gap-2">
          <a href="{{ path('app_administrateur_tca_import', {entite: entite.id}) }}" class="btn btn-warning">
            <i class="bi bi-upload"></i> Import
          </a>
          <a href="{{ path('app_administrateur_tca_new', {entite: entite.id}) }}" class="btn btn-outline-light">
            <i class="bi bi-plus-lg"></i> Ajouter
          </a>
        </div>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  {# TOOLBAR Export (comme TOTAL) #}
  <div class="filterbar mb-3">
    <div class="filterbar__top">
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <div class="filter-icon"><i class="bi bi-sliders"></i></div>
        <div>
          <div class="fw-bold">Outils</div>
          <div class="text-muted small">Recherche + export</div>
        </div>
      </div>

      <div class="ms-auto d-flex gap-2 align-items-center">
        <div class="dropdown">
          <button class="btn btn-warning btn-sm fw-semibold dropdown-toggle" data-bs-toggle="dropdown">
            <i class="bi bi-download"></i> Export
          </button>
          <ul class="dropdown-menu dropdown-menu-end" id="exportMenu"></ul>
        </div>
      </div>
    </div>
  </div>

  <div class="table-card mb-4 p-3 bg-white rounded-4">
    <table id="tableauTca" class="table table-hover align-middle mb-0 w-100">
      <thead>
        <tr>
          <th>#</th>
          <th>Journée</th>
          <th>Horaire</th>
          <th>Véhicule</th>
          <th>Agent</th>
          <th class="text-end">Qté</th>
          <th class="text-end">PU</th>
          <th class="text-end">Cuve</th>
          <th class="text-end"></th>
        </tr>
      </thead>
      <tbody></tbody>
    </table>
  </div>

  {# Modale delete #}
  <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Confirmer la suppression</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
        </div>
        <div class="modal-body">Cette suppression est définitive. Continuer ?</div>
        <div class="modal-footer">
          <button type="button" class="btn btn-light" data-bs-dismiss="modal">Annuler</button>
          <form id="deleteForm" method="post" action="">
            <input type="hidden" name="_token" id="deleteToken" value="">
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Supprimer</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script>
  $(function(){
    function nowLabel(){
      const d = new Date();
      return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
    }

    const table = $('#tableauTca').DataTable({
      serverSide:true,
      processing:true,
      autoWidth:false,
      scrollX:true,
      scrollCollapse:true,
      responsive:false,

      ajax:{
        url:"{{ path('app_administrateur_tca_ajax', { entite: entite.id }) }}",
        type:"POST",
      },

      dom:
        '<"dt-top d-flex flex-wrap gap-2 align-items-center justify-content-between"'
          + '<"dt-actions d-flex gap-2 align-items-center"B>'
          + '<"dt-search"f>'
        + '>'
        + 'rt'
        + '<"dt-bottom-internal d-flex flex-wrap gap-2 align-items-center justify-content-between"lip>',

      buttons:['copy','csv','excel','pdf','print'],
      lengthMenu:[[10,25,50,200],[10,25,50,200]],
      order:[[0,'desc']],
      language:{ url:'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json' },
      pageLength: 25,
      columns:[
        {data:'id'},
        {data:'journee'},
        {data:'horaire'},
        {data:'vehicule'},
        {data:'agent'},
        {data:'quantite'},
        {data:'prix'},
        {data:'cuve'},
        {data:'actions'}
      ],
      columnDefs:[
        {targets:[5,6,7,8], className:'text-end'},
        {targets:8, className:'action-column text-end', orderable:false, searchable:false},
        {type:'num', targets:0}
      ],

      initComplete:function(){
        const api = this.api();
        const $btns = $(api.buttons().container()).find('button');

        // ✅ construit le menu Export comme TOTAL
        $('#exportMenu').empty();
        $btns.each(function(){
          const $b=$(this);
          $('<li><a class="dropdown-item" href="#">'+$b.text()+'</a></li>')
            .on('click', e => { e.preventDefault(); $b.click(); })
            .appendTo('#exportMenu');
        });

        // ✅ cache les boutons natifs DataTables
        $(api.buttons().container()).hide();

        api.columns.adjust();
      },
    });

    table.on('draw.dt', function(){
      $('#hero-last-refresh').text('Maj : ' + nowLabel());
      table.columns.adjust();
    });

    $(document).on('click', '.delete-btn', function(){
      $('#deleteForm').attr('action', $(this).data('url'));
      $('#deleteToken').val($(this).data('token') || '');
    });
  });
  </script>




  <script>
  (function(){
    function getMenuFromToggle(toggle){
      return toggle?.parentElement?.querySelector('.dropdown-menu');
    }

    document.addEventListener('show.bs.dropdown', function(e){
      const toggle = e.target;
      const menu = getMenuFromToggle(toggle);
      if(!menu) return;

      if(menu.classList.contains('dropdown-menu-floating')) return;

      menu._originalParent = menu.parentElement;

      document.body.appendChild(menu);
      menu.classList.add('dropdown-menu-floating');

      if (window.Popper) {
        menu._popperInstance = Popper.createPopper(toggle, menu, {
          placement: 'bottom-end',
          strategy: 'fixed',
          modifiers: [
            { name: 'offset', options: { offset: [0, 6] } },
            { name: 'preventOverflow', options: { boundary: 'viewport', padding: 8 } },
          ],
        });
      } else {
        const r = toggle.getBoundingClientRect();
        menu.style.position = 'fixed';
        menu.style.top = (r.bottom + 6) + 'px';
        menu.style.left = (r.right - menu.offsetWidth) + 'px';
      }
    });

    document.addEventListener('hidden.bs.dropdown', function(e){
      const toggle = e.target;
      const menu = getMenuFromToggle(toggle);
      if(!menu || !menu.classList.contains('dropdown-menu-floating')) return;

      if (menu._popperInstance) {
        menu._popperInstance.destroy();
        menu._popperInstance = null;
      }

      if (menu._originalParent) {
        menu._originalParent.appendChild(menu);
      }

      menu.classList.remove('dropdown-menu-floating');
      menu._originalParent = null;
    });
  })();
  </script>
{% endblock %}