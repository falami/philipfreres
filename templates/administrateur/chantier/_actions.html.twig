<div class="btn-group btn-group-sm" role="group">
  <a class="btn btn-light"
     href="{{ path('app_administrateur_chantier_modifier', {entite: entite.id, id: chantier.id}) }}">
    <i class="bi bi-pencil"></i>
  </a>

  <button type="button" class="btn btn-light dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown">
    <span class="visually-hidden">Actions</span>
  </button>

  <ul class="dropdown-menu dropdown-menu-end">
    <li>
      <a class="dropdown-item" href="{{ path('app_administrateur_chantier_show', {entite: entite.id, id: chantier.id}) }}">
        <i class="bi bi-eye me-2"></i>Afficher
      </a>
    </li>
    <li>
      <a class="dropdown-item" href="{{ path('app_administrateur_chantier_pdf', {entite: entite.id, id: chantier.id}) }}" target="_blank">
        <i class="bi bi-file-earmark-pdf me-2"></i>PDF
      </a>
    </li>
    <li><hr class="dropdown-divider"></li>
    <li>
      <button type="button"
              class="dropdown-item text-danger delete-btn"
              data-bs-toggle="modal"
              data-bs-target="#deleteModal"
              data-url="{{ path('app_administrateur_chantier_supprimer', {entite: entite.id, id: chantier.id}) }}"
              data-token="{{ csrf_token('delete_chantier_' ~ chantier.id) }}">
        <i class="bi bi-trash me-2"></i>Supprimer
      </button>
    </li>
  </ul>
</div>