<div class="btn-group btn-group-sm chantier-actions" role="group">

  <a class="btn btn-light chantier-main"
     data-bs-toggle="tooltip" title="Modifier"
     href="{{ path('app_administrateur_chantier_modifier', { entite: entite.id, id: chantier.id }) }}">
    <i class="bi bi-pencil"></i>
  </a>

  <button type="button"
          class="btn btn-light dropdown-toggle dropdown-toggle-split chantier-split"
          data-bs-toggle="dropdown"
          data-bs-auto-close="outside"
          aria-expanded="false">
    <span class="visually-hidden">Actions</span>
  </button>

  <ul class="dropdown-menu dropdown-menu-end chantier-menu">
    <li>
      <a class="dropdown-item d-flex align-items-center"
         href="{{ path('app_administrateur_chantier_show', { entite: entite.id, id: chantier.id }) }}">
        <i class="bi bi-eye me-2"></i> Afficher
      </a>
    </li>

    <li>
      <a class="dropdown-item d-flex align-items-center"
         href="{{ path('app_administrateur_chantier_pdf', { entite: entite.id, id: chantier.id }) }}"
         target="_blank">
        <i class="bi bi-file-earmark-pdf me-2"></i> PDF
      </a>
    </li>

    <li><hr class="dropdown-divider"></li>

    <li>
      <button type="button"
              class="dropdown-item d-flex align-items-center text-danger delete-btn"
              data-bs-toggle="modal"
              data-bs-target="#deleteModal"
              data-url="{{ path('app_administrateur_chantier_supprimer', { entite: entite.id, id: chantier.id }) }}"
              data-token="{{ csrf_token('delete_chantier_' ~ chantier.id) }}">
        <i class="bi bi-trash me-2"></i> Supprimer
      </button>
    </li>
  </ul>
</div>