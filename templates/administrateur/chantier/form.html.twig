  <script>
  window.CHANTIER_DEFAULT_LOCATION = {
    address: {{ [
      chantier.adresse ?? '',
      chantier.complement ?? '',
      chantier.codePostal ?? '',
      chantier.ville ?? ''
    ]|filter(v => v is not empty)|join(' ')|json_encode|raw }},
    lat: null,
    lng: null
  };
</script>

  <script>
    document.addEventListener('DOMContentLoaded', async () => {
      if (window.flatpickr && window.flatpickr.l10ns && window.flatpickr.l10ns.fr) {
        flatpickr.localize(flatpickr.l10ns.fr);
      }

      const formMain = document.querySelector('form[name="chantier_administrateur"]');
      const submitButtons = formMain ? [...formMain.querySelectorAll('button[type="submit"]')] : [];

      let currentBrowserLocationPromise = null;

      function getBrowserLocation() {
        if (currentBrowserLocationPromise) {
          return currentBrowserLocationPromise;
        }

        currentBrowserLocationPromise = new Promise((resolve) => {
          if (!navigator.geolocation) {
            resolve(null);
            return;
          }

          navigator.geolocation.getCurrentPosition(
            async (position) => {
              const lat = Number(position.coords.latitude).toFixed(7);
              const lng = Number(position.coords.longitude).toFixed(7);

              let address = null;

              try {
                const url = new URL("{{ path('app_administrateur_chantier_reverse_geocode', {entite: entite.id}) }}", window.location.origin);
                url.searchParams.set('lat', lat);
                url.searchParams.set('lng', lng);

                const response = await fetch(url.toString(), {
                  headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                const data = await response.json();

                if (response.ok && data.ok) {
                  address = data.display_name || null;
                }
              } catch (_) {}

              resolve({
                lat,
                lng,
                address,
                source: 'browser'
              });
            },
            () => resolve(null),
            {
              enableHighAccuracy: true,
              timeout: 8000,
              maximumAge: 120000
            }
          );
        });

        return currentBrowserLocationPromise;
      }

      async function applyDefaultLocationToPhotoItem(item) {
        if (!item || item.dataset.defaultLocationApplied === '1') {
          return;
        }

        item.dataset.defaultLocationApplied = '1';

        const browserLocation = await getBrowserLocation();

        ['avant', 'apres'].forEach(kind => {
          const latInput = item.querySelector(`.js-photo-lat-${kind}`);
          const lngInput = item.querySelector(`.js-photo-lng-${kind}`);
          const sourceInput = item.querySelector(`.js-photo-source-${kind}`);
          const addressInput = item.querySelector(`.js-photo-address-${kind}`);
          const latVisible = item.querySelector(`.js-photo-lat-visible-${kind}`);
          const lngVisible = item.querySelector(`.js-photo-lng-visible-${kind}`);

          if (!latInput || !lngInput) return;
          if (latInput.value && lngInput.value) return;

          if (browserLocation) {
            latInput.value = browserLocation.lat;
            lngInput.value = browserLocation.lng;

            if (latVisible) latVisible.value = browserLocation.lat;
            if (lngVisible) lngVisible.value = browserLocation.lng;
            if (sourceInput) sourceInput.value = browserLocation.source;
            if (addressInput && browserLocation.address && !addressInput.value) {
              addressInput.value = browserLocation.address;
            }

            return;
          }

          const chantierAddress = (window.CHANTIER_DEFAULT_LOCATION?.address || '').trim();
          if (chantierAddress && addressInput && !addressInput.value) {
            addressInput.value = chantierAddress;
          }
        });
      }

      function initFlatpickr(scope = document) {
        if (!window.flatpickr) return;

        const selectors = [
          'input[type="date"]',
          '.js-datepicker',
          '[data-flatpickr]'
        ];

        scope.querySelectorAll(selectors.join(',')).forEach(el => {
          if (el._flatpickr) return;

          flatpickr(el, {
            dateFormat: 'Y-m-d',
            altInput: true,
            altFormat: 'd/m/Y',
            allowInput: true,
            locale: 'fr'
          });
        });
      }

      function initTomSelectOn(el, options = {}) {
        if (!el || el.tomselect) return;

        const isMultiple = el.hasAttribute('multiple');

        new TomSelect(el, Object.assign({
          dropdownParent: 'body',
          create: false,
          allowEmptyOption: true,
          plugins: isMultiple ? ['remove_button'] : [],
          sortField: { field: 'text', direction: 'asc' },
          onChange: () => refreshResume()
        }, options));
      }

      function initTomSelect(scope = document) {
        if (!window.TomSelect) return;

        scope.querySelectorAll('select').forEach(select => {
          if (
            select.classList.contains('no-tomselect') ||
            select.dataset.noTomselect === '1'
          ) {
            return;
          }

          initTomSelectOn(select);
        });
      }

      function initWidgets(scope = document) {
        initFlatpickr(scope);
        initTomSelect(scope);
      }

      function initRealDatesDefaults() {
        const debutPrev = document.getElementById('{{ form.dateDebutPrevisionnelle.vars.id }}');
        const finPrev = document.getElementById('{{ form.dateFinPrevisionnelle.vars.id }}');
        const debutReel = document.getElementById('{{ form.dateDebutReelle.vars.id }}');
        const finReel = document.getElementById('{{ form.dateFinReelle.vars.id }}');

        function syncDate(source, target) {
          if (!source || !target) return;

          const copy = () => {
            if (!target.value && source.value) {
              target.value = source.value;

              if (target._flatpickr) {
                target._flatpickr.setDate(source.value, true);
              }
            }
          };

          copy();
          source.addEventListener('change', copy);
        }

        syncDate(debutPrev, debutReel);
        syncDate(finPrev, finReel);
      }
      
      async function initPhotoMaps(scope = document) {
        const items = [...scope.querySelectorAll('.js-photo-item')];

        for (const item of items) {
          if (item.dataset.mapInit === '1') continue;

          await applyDefaultLocationToPhotoItem(item);
          item.dataset.mapInit = '1';

          const configs = ['avant', 'apres'];

          for (const kind of configs) {
            const mapEl = item.querySelector(`.js-photo-map[data-kind="${kind}"]`);
            const addressInput = item.querySelector(`.js-photo-address-${kind}`);
            const latInput = item.querySelector(`.js-photo-lat-${kind}`);
            const lngInput = item.querySelector(`.js-photo-lng-${kind}`);
            const sourceInput = item.querySelector(`.js-photo-source-${kind}`);
            const latVisible = item.querySelector(`.js-photo-lat-visible-${kind}`);
            const lngVisible = item.querySelector(`.js-photo-lng-visible-${kind}`);
            const geocodeBtn = item.querySelector(`.js-geocode-photo[data-kind="${kind}"]`);
            const applyCoordsBtn = item.querySelector(`.js-apply-coords[data-kind="${kind}"]`);

            if (!mapEl || !latInput || !lngInput) continue;
            if (mapEl.dataset.mapReady === '1') continue;
            mapEl.dataset.mapReady = '1';

            const defaultLat = parseFloat(latInput.value || '43.604652');
            const defaultLng = parseFloat(lngInput.value || '1.444209');
            const hasCoords = !!(latInput.value && lngInput.value);

            if (latVisible) latVisible.value = latInput.value || '';
            if (lngVisible) lngVisible.value = lngInput.value || '';

            const map = L.map(mapEl).setView([defaultLat, defaultLng], hasCoords ? 17 : 6);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
              maxZoom: 20,
              attribution: '&copy; OpenStreetMap'
            }).addTo(map);

            const marker = L.marker([defaultLat, defaultLng], {
              draggable: true
            }).addTo(map);

            if (!hasCoords) {
              marker.setOpacity(0.55);
            }

            async function setCoords(lat, lng, source = 'manuel', center = true, updateAddress = false) {
              latInput.value = Number(lat).toFixed(7);
              lngInput.value = Number(lng).toFixed(7);

              if (latVisible) latVisible.value = latInput.value;
              if (lngVisible) lngVisible.value = lngInput.value;
              if (sourceInput) sourceInput.value = source;

              marker.setLatLng([lat, lng]);
              marker.setOpacity(1);

              if (center) {
                map.setView([lat, lng], Math.max(map.getZoom(), 17));
              }

              if (updateAddress && addressInput) {
                try {
                  const url = new URL("{{ path('app_administrateur_chantier_reverse_geocode', {entite: entite.id}) }}", window.location.origin);
                  url.searchParams.set('lat', lat);
                  url.searchParams.set('lng', lng);

                  const response = await fetch(url.toString(), {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                  });

                  const data = await response.json();

                  if (response.ok && data.ok && data.display_name) {
                    addressInput.value = data.display_name;
                  }
                } catch (_) {}
              }
            }

            marker.on('dragend', async () => {
              const pos = marker.getLatLng();
              await setCoords(pos.lat, pos.lng, 'manuel', false, true);
            });

            map.on('click', async (e) => {
              await setCoords(e.latlng.lat, e.latlng.lng, 'manuel', false, true);
            });

            applyCoordsBtn?.addEventListener('click', async () => {
              const lat = parseFloat(latVisible?.value || '');
              const lng = parseFloat(lngVisible?.value || '');

              if (!Number.isFinite(lat) || !Number.isFinite(lng)) {
                alert('Latitude / longitude invalides.');
                return;
              }

              await setCoords(lat, lng, 'manuel', true, true);
            });

            geocodeBtn?.addEventListener('click', async () => {
              const address = (addressInput?.value || '').trim();
              if (!address) {
                alert('Merci de saisir une adresse.');
                return;
              }

              geocodeBtn.disabled = true;

              try {
                const url = new URL("{{ path('app_administrateur_chantier_geocode', {entite: entite.id}) }}", window.location.origin);
                url.searchParams.set('q', address);

                const response = await fetch(url.toString(), {
                  headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                const data = await response.json();

                if (!response.ok || !data.ok) {
                  throw new Error(data.message || 'Adresse introuvable');
                }

                const lat = parseFloat(data.latitude);
                const lng = parseFloat(data.longitude);

                if (addressInput && data.display_name) {
                  addressInput.value = data.display_name;
                }

                await setCoords(lat, lng, 'geocodage', true, false);
                setTimeout(() => map.invalidateSize(), 120);
              } catch (e) {
                alert(e.message || 'Erreur lors de la localisation.');
              } finally {
                geocodeBtn.disabled = false;
              }
            });

            setTimeout(() => map.invalidateSize(), 150);
          }
        }
      }


      function initPhotoUploadUI(scope = document) {
        scope.querySelectorAll('.js-dropzone').forEach(zone => {
          if (zone.dataset.uploadInit === '1') return;
          zone.dataset.uploadInit = '1';

          const inputId = zone.dataset.targetInputId;
          const input = zone.querySelector(`#${CSS.escape(inputId)}`) || document.getElementById(inputId);
          const preview = zone.querySelector('.js-photo-preview');
          const previewImg = zone.querySelector('.js-photo-preview-img');
          const replaceBtn = zone.querySelector('.js-photo-replace');
          const removeBtn = zone.querySelector('.js-photo-remove');
          const inner = zone.querySelector('.photo-dropzone__inner');

          if (!input || !preview || !previewImg || !inner) return;

          function showPreview(file) {
            if (!file || !file.type.startsWith('image/')) return;

            const reader = new FileReader();
            reader.onload = e => {
              previewImg.src = e.target.result;
              preview.classList.remove('d-none');
              inner.classList.add('d-none');
            };
            reader.readAsDataURL(file);
          }

          function clearPreview() {
            input.value = '';
            previewImg.src = '';
            preview.classList.add('d-none');
            inner.classList.remove('d-none');
          }

          zone.addEventListener('click', e => {
            if (e.target.closest('.js-photo-remove') || e.target.closest('.js-photo-replace')) return;
            input.click();
          });

          replaceBtn?.addEventListener('click', e => {
            e.preventDefault();
            e.stopPropagation();
            input.click();
          });

          removeBtn?.addEventListener('click', e => {
            e.preventDefault();
            e.stopPropagation();
            clearPreview();
          });

          input.addEventListener('change', () => {
            const file = input.files?.[0];
            if (file) {
              showPreview(file);
            } else {
              clearPreview();
            }
          });

          ['dragenter', 'dragover'].forEach(eventName => {
            zone.addEventListener(eventName, e => {
              e.preventDefault();
              e.stopPropagation();
              zone.classList.add('is-dragover');
            });
          });

          ['dragleave', 'dragend', 'drop'].forEach(eventName => {
            zone.addEventListener(eventName, e => {
              e.preventDefault();
              e.stopPropagation();
              zone.classList.remove('is-dragover');
            });
          });

          zone.addEventListener('drop', e => {
            const files = e.dataTransfer?.files;
            if (!files || !files.length) return;

            const file = files[0];
            if (!file.type.startsWith('image/')) return;

            const dt = new DataTransfer();
            dt.items.add(file);
            input.files = dt.files;
            input.dispatchEvent(new Event('change', { bubbles: true }));
          });
        });
      }

      function bindRemoveButtons(scope = document) {
        scope.querySelectorAll('.remove-collection-item').forEach(btn => {
          if (btn.dataset.bound === '1') return;
          btn.dataset.bound = '1';

          btn.addEventListener('click', () => {
            const holder = btn.closest('.collection-holder') || btn.parentElement?.parentElement;
            btn.closest('.collection-item')?.remove();
            ensureEmptyPlaceholders();
            refreshResume();
          });
        });
      }

      function ensureEmptyPlaceholders() {
        document.querySelectorAll('.collection-holder').forEach(holder => {
          const items = holder.querySelectorAll('.collection-item');
          let placeholder = holder.querySelector('.empty-placeholder');

          if (!items.length) {
            if (!placeholder) {
              placeholder = document.createElement('div');
              placeholder.className = 'collection-empty empty-placeholder';
              placeholder.innerHTML = '<i class="bi bi-inbox me-1"></i> Aucun élément ajouté pour le moment.';
              holder.appendChild(placeholder);
            }
          } else if (placeholder) {
            placeholder.remove();
          }
        });
      }

      document.querySelectorAll('.add-collection-item').forEach(btn => {
        btn.addEventListener('click', async () => {
          const holder = document.querySelector(btn.dataset.collectionHolder);
          if (!holder) return;

          const placeholder = holder.querySelector('.empty-placeholder');
          if (placeholder) placeholder.remove();

          const index = parseInt(holder.dataset.index || '0', 10);
          const proto = holder.dataset.prototype.replace(/__name__/g, index);

          const item = document.createElement('div');
          item.className = 'collection-item';
          item.innerHTML = `
            <button type="button" class="btn btn-outline-danger btn-sm remove-collection-item">
              <i class="bi bi-trash"></i>
            </button>
            ${proto}
          `;

          holder.appendChild(item);
          holder.dataset.index = String(index + 1);

          bindRemoveButtons(item);
          initWidgets(item);
          initPhotoUploadUI(item);
          await initPhotoMaps(item);
          refreshResume();
        });
      });

      const fields = {
        nom: document.getElementById('{{ form.nom.vars.id }}'),
        statut: document.getElementById('{{ form.statut.vars.id }}'),
        ville: document.getElementById('{{ form.ville.vars.id }}')
      };

      const resume = {
        nom: document.getElementById('resume-nom'),
        statut: document.getElementById('resume-statut'),
        ville: document.getElementById('resume-ville'),
        zones: document.getElementById('resume-zones'),
        rh: document.getElementById('resume-rh'),
        engins: document.getElementById('resume-engins'),
        materiels: document.getElementById('resume-materiels'),
        dechets: document.getElementById('resume-dechets'),
        photos: document.getElementById('resume-photos'),
        pill: document.getElementById('resume-valid-pill')
      };

      function selectedText(selectEl) {
        if (!selectEl || !selectEl.value) return '';
        const opt = selectEl.selectedOptions && selectEl.selectedOptions[0];
        return (opt ? opt.textContent : '').trim();
      }

      function countItems(selector) {
        return document.querySelectorAll(selector + ' .collection-item').length;
      }

      function refreshResume() {
        if (resume.nom) resume.nom.textContent = (fields.nom?.value || '').trim() || '-';
        if (resume.statut) resume.statut.textContent = selectedText(fields.statut) || '-';
        if (resume.ville) resume.ville.textContent = (fields.ville?.value || '').trim() || '-';

        if (resume.zones) resume.zones.textContent = countItems('#zones-holder');
        if (resume.rh) resume.rh.textContent = countItems('#ressourcesHumaines-holder');
        if (resume.engins) resume.engins.textContent = countItems('#ressourcesEngins-holder');
        if (resume.materiels) resume.materiels.textContent = countItems('#ressourcesMateriels-holder');
        if (resume.dechets) resume.dechets.textContent = countItems('#dechets-holder');
        if (resume.photos) resume.photos.textContent = countItems('#photos-holder');

        const hasNom = !!((fields.nom?.value || '').trim());
        const hasStatut = !!((fields.statut?.value || '').trim());
        const hasVille = !!((fields.ville?.value || '').trim());

        const ok = hasNom && hasStatut && hasVille && (formMain ? formMain.checkValidity() : true);

        submitButtons.forEach(btn => btn.disabled = !ok);

        if (resume.pill) {
          if (ok) {
            resume.pill.textContent = '✅ Complet';
            resume.pill.style.background = 'rgba(25,135,84,.15)';
            resume.pill.style.borderColor = 'rgba(25,135,84,.35)';
            resume.pill.style.color = 'var(--ink)';
          } else {
            resume.pill.textContent = '⚠️ Incomplet';
            resume.pill.style.background = 'rgba(255,193,7,.15)';
            resume.pill.style.borderColor = 'rgba(255,193,7,.35)';
            resume.pill.style.color = 'var(--ink)';
          }
        }
      }

      function initFormValidation({ formName }) {
        const form = document.querySelector(`form[name="${formName}"]`);
        if (!form) return;

        const submitButton = form.querySelector('button[type="submit"]');
        if (!submitButton) return;

        let errorAlert = document.getElementById('form-error-alert');
        if (!errorAlert) {
          errorAlert = document.createElement('div');
          errorAlert.className = 'alert alert-danger d-none';
          errorAlert.id = 'form-error-alert';
          submitButton.parentElement.prepend(errorAlert);
        }

        form.addEventListener('submit', e => {
          const messages = new Set();
          let first = null;

          form.querySelectorAll(':invalid').forEach(el => {
            el.classList.add('is-invalid');
            if (!first) first = el;

            const label = form.querySelector(`label[for="${el.id}"]`);
            if (label) messages.add(`- ${label.textContent.trim()}`);
          });

          if (messages.size) {
            e.preventDefault();
            errorAlert.innerHTML = `<strong>Champs requis manquants :</strong><br>${[...messages].join('<br>')}`;
            errorAlert.classList.remove('d-none');

            if (first && first.scrollIntoView) {
              first.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }

            setTimeout(() => errorAlert.classList.add('d-none'), 6000);
          }
        });
      }

      [fields.nom, fields.ville].forEach(el => {
        el?.addEventListener('input', refreshResume);
        el?.addEventListener('change', refreshResume);
      });

      fields.statut?.addEventListener('change', refreshResume);



      function initQuickResourceModal() {
        const modalEl = document.getElementById('quickResourceModal');
        if (!modalEl || !window.bootstrap) return;

        const modal = new bootstrap.Modal(modalEl);

        const config = {
          utilisateur: {
            title: 'Ajouter une ressource humaine',
            nomLabel: 'Nom',
            selectName: '[utilisateur]',
            fields: ['prenom', 'email']
          },
          engin: {
            title: 'Ajouter un engin',
            nomLabel: 'Nom de l’engin',
            selectName: '[engin]',
            fields: ['immatriculation']
          },
          materiel: {
            title: 'Ajouter un matériel',
            nomLabel: 'Nom du matériel',
            selectName: '[materiel]',
            fields: ['type', 'numeroSerie']
          },
          dechet: {
            title: 'Ajouter un déchet',
            nomLabel: 'Nom du déchet',
            selectName: '[typeDechet]',
            fields: ['unite']
          }
        };

        const kindInput = document.getElementById('quickResourceKind');
        const title = document.getElementById('quickResourceTitle');
        const nomLabel = document.getElementById('quickResourceNomLabel');
        const nomInput = document.getElementById('quickResourceNom');
        const prenomInput = document.getElementById('quickResourcePrenom');
        const emailInput = document.getElementById('quickResourceEmail');
        const immatriculationInput = document.getElementById('quickResourceImmatriculation');
        const typeInput = document.getElementById('quickResourceType');
        const numeroSerieInput = document.getElementById('quickResourceNumeroSerie');
        const uniteInput = document.getElementById('quickResourceUnite');
        const errorBox = document.getElementById('quickResourceError');
        const submitBtn = document.getElementById('quickResourceSubmit');

        function hideError() {
          errorBox.classList.add('d-none');
          errorBox.textContent = '';
        }

        function showError(message) {
          errorBox.textContent = message || 'Erreur inconnue.';
          errorBox.classList.remove('d-none');
        }

        function resetFields() {
          hideError();

          [nomInput, prenomInput, emailInput, immatriculationInput, typeInput, numeroSerieInput].forEach(input => {
            if (input) input.value = '';
          });

          if (uniteInput) uniteInput.value = 'kg';

          document.querySelectorAll(
            '.js-field-prenom, .js-field-email, .js-field-immatriculation, .js-field-type, .js-field-numero-serie, .js-field-unite'
          ).forEach(el => el.classList.add('d-none'));
        }

        function openModal(kind) {
          const cfg = config[kind];
          if (!cfg) return;

          resetFields();

          kindInput.value = kind;
          title.textContent = cfg.title;
          nomLabel.textContent = cfg.nomLabel;

          cfg.fields.forEach(field => {
            const fieldEl = document.querySelector(`.js-field-${field}`);
            if (fieldEl) fieldEl.classList.remove('d-none');
          });

          modal.show();

          setTimeout(() => {
            if (kind === 'utilisateur') {
              prenomInput?.focus();
            } else {
              nomInput?.focus();
            }
          }, 250);
        }

        function addOptionToMatchingSelects(kind, id, label) {
          const cfg = config[kind];
          if (!cfg) return;

          const selector = `select[name$="${cfg.selectName}"]`;
          const selects = [...document.querySelectorAll(selector)];

          selects.forEach(select => {
            const value = String(id);

            if (select.tomselect) {
              if (!select.tomselect.options[value]) {
                select.tomselect.addOption({ value, text: label });
              }

              select.tomselect.refreshOptions(false);

              if (!select.value) {
                select.tomselect.setValue(value, true);
              }

              return;
            }

            if (![...select.options].some(opt => opt.value === value)) {
              const option = new Option(label, value, false, !select.value);
              select.add(option);
            }
          });
        }

        document.querySelectorAll('.js-open-quick-resource').forEach(btn => {
          btn.addEventListener('click', () => openModal(btn.dataset.kind));
        });

        submitBtn?.addEventListener('click', async () => {
          const kind = kindInput.value;
          const nom = (nomInput.value || '').trim();

          if (!nom) {
            showError('Le nom est obligatoire.');
            return;
          }

          if (kind === 'utilisateur' && !(prenomInput.value || '').trim()) {
            showError('Le prénom est obligatoire.');
            return;
          }

          submitBtn.disabled = true;
          hideError();

          const body = new URLSearchParams();
          body.set('_token', '{{ csrf_token('chantier_inline_resource') }}');
          body.set('kind', kind);
          body.set('nom', nom);
          body.set('prenom', prenomInput?.value || '');
          body.set('email', emailInput?.value || '');
          body.set('immatriculation', immatriculationInput?.value || '');
          body.set('type', typeInput?.value || '');
          body.set('numeroSerie', numeroSerieInput?.value || '');
          body.set('unite', uniteInput?.value || 'kg');

          try {
            const response = await fetch('{{ path('app_administrateur_chantier_ajax_ressource_creer', { entite: entite.id }) }}', {
              method: 'POST',
              headers: {
                'X-Requested-With': 'XMLHttpRequest',
                'Content-Type': 'application/x-www-form-urlencoded'
              },
              body
            });

            const data = await response.json();

            if (!response.ok || !data.ok) {
              throw new Error(data.message || 'Impossible de créer la ressource.');
            }

            addOptionToMatchingSelects(data.kind, data.id, data.label);

            modal.hide();
            refreshResume();
          } catch (e) {
            showError(e.message || 'Erreur lors de la création.');
          } finally {
            submitBtn.disabled = false;
          }
        });
      }

      initWidgets(document);
      initRealDatesDefaults();
      initQuickResourceModal();
      initPhotoUploadUI(document);
      bindRemoveButtons(document);
      ensureEmptyPlaceholders();
      initFormValidation({ formName: 'chantier_administrateur' });
      await initPhotoMaps(document);
      refreshResume();
    });
  </script>
{% endblock %}