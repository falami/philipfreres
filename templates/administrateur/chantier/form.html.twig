{# templates/administrateur/chantier/form.html.twig #}
{% extends 'base_admin.html.twig' %}
{% block title %}{{ modeEdition ? 'Modification' : 'Création' }} d'un chantier{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('dist/css/formulaire.css') }}">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css">

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --theme-color-tertiaire: {{ themeColorTertiaire|default(entite.couleurTertiaire|default('#F0F0F0')) }};
      --theme-color-quaternaire: {{ couleurQuaternaire|default(entite.couleurQuaternaire|default('#000000')) }};

      --bg: #f5f7fb;
      --panel: #ffffff;
      --ink: #0f172a;
      --muted:#64748b;
      --stroke: rgba(15, 23, 42, .10);
      --shadow: 0 18px 55px rgba(15, 23, 42, .10);
      --radius: 18px;
    }

    body{
      background: var(--bg);
    }

    /* =========================
       HERO
       ========================= */
    .hero{
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      color: #fff;
      box-shadow: 0 18px 50px rgba(0,0,0,.14);
      background:
        radial-gradient(1200px 420px at 12% -10%,
          color-mix(in srgb, var(--theme-color-tertiaire) 35%, transparent),
          transparent 58%
        ),
        radial-gradient(900px 380px at 92% 0%,
          color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent),
          transparent 60%
        ),
        radial-gradient(700px 260px at 55% 115%,
          color-mix(in srgb, var(--theme-color-quaternaire) 18%, transparent),
          transparent 62%
        ),
        linear-gradient(135deg,
          color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%),
          color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%)
        );
    }

    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
      opacity:.85;
    }

    .hero .accent{
      width: 12px;
      border-radius: 999px;
      background: var(--theme-color-secondaire);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
    }

    .hero .chip{
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.32rem .7rem;
      border-radius: 999px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(255,255,255,.14);
      font-size:.82rem;
      color: rgba(255,255,255,.92);
      backdrop-filter: blur(6px);
      white-space: nowrap;
    }

    .hero .chip i{
      color: var(--theme-color-secondaire);
    }

    .hero .chip--pill{
      background: color-mix(in srgb, var(--theme-color-secondaire) 18%, transparent);
      border-color: color-mix(in srgb, var(--theme-color-secondaire) 28%, rgba(255,255,255,.14));
      color:#fff;
    }

    .hero .btn{
      border-radius: 14px;
      font-weight: 800;
    }

    .hero .btn-outline-theme{
      border-color: rgba(255,255,255,.35);
      color:#fff;
    }

    .hero .btn-outline-theme:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.55);
      color:#fff;
    }

    /* =========================
       Cards premium
       ========================= */
    .cardx{
      background: var(--panel);
      border: 1px solid var(--stroke);
      border-radius: var(--radius);
      box-shadow: 0 10px 28px rgba(15,23,42,.08);
      overflow: hidden;
    }

    .cardx-h{
      padding: .95rem 1.05rem;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:1rem;
      background: linear-gradient(180deg, rgba(0,0,0,.015), transparent);
      border-bottom: 1px solid var(--stroke);
    }

    .cardx-title{
      margin:0;
      font-weight:800;
      letter-spacing:-.01em;
      color: var(--ink);
      display:flex;
      align-items:center;
      gap:.6rem;
    }

    .chip{
      font-size:.78rem;
      padding:.25rem .55rem;
      border-radius:999px;
      background: color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--theme-color-principal) 18%, var(--stroke));
      color: var(--muted);
      white-space:nowrap;
    }

    /* =========================
       Form polish
       ========================= */
    label.form-label{
      font-weight: 700;
      color: var(--ink);
    }

    .form-text, .text-muted, .small{
      color: var(--muted) !important;
    }

    .form-control,
    .form-select{
      border-radius: 14px;
      border: 1px solid var(--stroke);
      padding: .65rem .85rem;
    }

    .form-control:focus,
    .form-select:focus{
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke));
      box-shadow: 0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
    }

    textarea.form-control{
      min-height: 120px;
    }

    /* =========================
       Tom Select
       ========================= */
    .ts-wrapper .ts-control{
      border-radius: 14px !important;
      padding: .55rem .75rem !important;
      border-color: var(--stroke) !important;
      min-height: 46px;
      box-shadow: none !important;
    }

    .ts-wrapper.focus .ts-control{
      box-shadow: 0 0 0 .2rem color-mix(in srgb, var(--theme-color-principal) 18%, transparent) !important;
      border-color: color-mix(in srgb, var(--theme-color-principal) 55%, var(--stroke)) !important;
    }

    .ts-dropdown{
      z-index: 9999 !important;
      border-radius: 14px !important;
      border: 1px solid var(--stroke) !important;
      overflow: hidden;
    }

    .ts-wrapper.focus,
    .ts-wrapper.dropdown-active{
      z-index: 9999;
    }

    .card,
    .card-body,
    .container,
    .container-fluid,
    .cardx,
    .cardx *{
      overflow: visible;
    }

    /* =========================
       Collections
       ========================= */
    .collection-holder{
      display:flex;
      flex-direction:column;
      gap:1rem;
    }

    .collection-item{
      position: relative;
      border: 1px solid rgba(15,23,42,.08);
      border-radius: 18px;
      background:
        linear-gradient(180deg,
          color-mix(in srgb, var(--theme-color-principal) 4%, transparent),
          transparent
        ),
        #fff;
      box-shadow: 0 8px 22px rgba(15,23,42,.05);
      padding: 1rem;
    }

    .collection-item + .collection-item{
      margin-top: 0;
    }

    .collection-item .remove-collection-item{
      position:absolute;
      top:12px;
      right:12px;
      z-index:2;
      border-radius: 12px;
    }

    .collection-item .form-row,
    .collection-item .row{
      margin-top: 0;
    }

    .collection-empty{
      border: 1px dashed rgba(15,23,42,.14);
      border-radius: 18px;
      padding: 1rem 1.1rem;
      color: var(--muted);
      background: rgba(255,255,255,.75);
    }

    /* =========================
       Résumé / sticky
       ========================= */
    .sticky-actions{
      position: sticky;
      bottom: 14px;
      z-index: 5;
      background: color-mix(in srgb, var(--panel) 82%, transparent);
      backdrop-filter: blur(10px);
      border: 1px solid var(--stroke);
      border-radius: var(--radius);
      padding: .75rem;
      box-shadow: var(--shadow);
    }

    .resume-box{
      border-radius: 18px;
      padding: 1rem;
      border: 1px solid var(--stroke);
      background: linear-gradient(
        180deg,
        color-mix(in srgb, var(--theme-color-principal) 8%, transparent),
        transparent
      );
    }

    .resume-line{
      display:flex;
      justify-content:space-between;
      gap:1rem;
      padding:.42rem 0;
      border-bottom: 1px dashed rgba(15,23,42,.08);
    }

    .resume-line:last-child{
      border-bottom: none;
    }

    .resume-pill{
      border:1px solid var(--stroke);
      background: rgba(255,193,7,.15);
      color: var(--ink);
      border-radius: 999px;
      padding: .45rem .8rem;
      font-weight: 700;
      font-size: .84rem;
    }

    @media (max-width: 991.98px){
      .sticky-actions{
        position: static;
      }
    }

    @media (max-width:768px){
      .hero{ border-radius:16px; }
      .cardx{ border-radius:16px; }
      .collection-item{ border-radius:16px; }
    }

    .photo-location-box{
      margin-top: 1rem;
      padding: 1rem;
      border: 1px dashed rgba(15,23,42,.12);
      border-radius: 16px;
      background: rgba(248,250,252,.85);
    }

    .photo-map{
      width: 100%;
      height: 260px;
      border-radius: 16px;
      border: 1px solid rgba(15,23,42,.10);
      overflow: hidden;
      margin-top: .75rem;
    }

    .photo-location-help{
      font-size: .86rem;
      color: var(--muted);
    }


    .photo-card{
      border:1px solid rgba(15,23,42,.08);
      border-radius:20px;
      background:linear-gradient(180deg, rgba(255,255,255,.98), rgba(248,250,252,.96));
      box-shadow:0 16px 34px rgba(15,23,42,.08);
      padding:1rem;
      height:100%;
    }

    .photo-card__head{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:1rem;
      margin-bottom:.85rem;
    }

    .photo-card__title{
      font-weight:800;
      color:var(--ink);
      display:flex;
      align-items:center;
    }

    .photo-badge{
      display:inline-flex;
      align-items:center;
      padding:.32rem .7rem;
      border-radius:999px;
      font-size:.78rem;
      font-weight:700;
      background:rgba(13,110,253,.10);
      color:#0d6efd;
      border:1px solid rgba(13,110,253,.15);
    }

    .photo-badge--after{
      background:rgba(25,135,84,.10);
      color:#198754;
      border:1px solid rgba(25,135,84,.15);
    }

    .photo-dropzone{
      position:relative;
      border:1.5px dashed rgba(15,23,42,.16);
      border-radius:18px;
      background:
        radial-gradient(700px 120px at 50% -10%, rgba(255,193,7,.10), transparent 60%),
        linear-gradient(180deg, rgba(255,255,255,.9), rgba(248,250,252,.9));
      min-height:260px;
      overflow:hidden;
      transition:.2s ease;
      cursor:pointer;
    }

    .photo-dropzone:hover{
      border-color: rgba(255,193,7,.45);
      box-shadow:0 0 0 .25rem rgba(255,193,7,.10);
    }

    .photo-dropzone.is-dragover{
      border-color: rgba(25,135,84,.45);
      box-shadow:0 0 0 .25rem rgba(25,135,84,.10);
      transform: translateY(-1px);
    }

    .photo-dropzone__inner{
      min-height:260px;
      display:flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      text-align:center;
      padding:1rem;
    }

    .photo-dropzone__icon{
      width:68px;
      height:68px;
      border-radius:20px;
      display:grid;
      place-items:center;
      margin-bottom:.9rem;
      font-size:1.7rem;
      color:var(--theme-color-principal);
      background:color-mix(in srgb, var(--theme-color-principal) 10%, transparent);
      border:1px solid color-mix(in srgb, var(--theme-color-principal) 18%, transparent);
    }

    .photo-dropzone__title{
      font-weight:800;
      color:var(--ink);
    }

    .photo-dropzone__hint{
      margin-top:.25rem;
      color:var(--muted);
      font-size:.9rem;
    }

    .photo-preview{
      position:absolute;
      inset:0;
    }

    .photo-preview__img{
      width:100%;
      height:100%;
      object-fit:cover;
      display:block;
    }

    .photo-preview__overlay{
      position:absolute;
      inset:auto 0 0 0;
      display:flex;
      justify-content:center;
      gap:.5rem;
      padding:1rem;
      background:linear-gradient(180deg, transparent, rgba(15,23,42,.72));
    }
  </style>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="{{ asset('dist/vendors/flatpickr/flatpickr.min.js') }}"></script>
  <script src="https://npmcdn.com/flatpickr/dist/l10n/fr.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
  <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
{% endblock %}

{% block body %}

  {% set collections = {
    'zones': {'label':'Sous-chantiers / parcelles', 'icon':'bi-diagram-3', 'btn':'Ajouter un sous-chantier', 'chip':'Parcelles'},
    'ressourcesHumaines': {'label':'Ressources humaines', 'icon':'bi-people', 'btn':'Ajouter une ressource humaine', 'chip':'Équipe', 'quick':'utilisateur'},
    'ressourcesEngins': {'label':'Ressources engins', 'icon':'bi-truck', 'btn':'Ajouter un engin', 'chip':'Engins', 'quick':'engin'},
    'ressourcesMateriels': {'label':'Ressources matériel', 'icon':'bi-tools', 'btn':'Ajouter un matériel', 'chip':'Matériel', 'quick':'materiel'},
    'dechets': {'label':'Déchets', 'icon':'bi-recycle', 'btn':'Ajouter un déchet', 'chip':'Suivi', 'quick':'dechet'},
    'photos': {'label':'Photos avant / après', 'icon':'bi-images', 'btn':'Ajouter une paire de photos', 'chip':'Photos'}
  } %}

  <div class="hero p-3 mb-4 d-flex gap-3">
    <div class="accent"></div>

    <div class="flex-grow-1">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-cone-striped me-2" style="color:var(--theme-color-secondaire)"></i>
            {{ modeEdition ? 'Modification' : 'Création' }} d’un chantier
          </h2>
          <div class="opacity-75 mt-1">Pilotage du chantier, parcelles, ressources, déchets et suivi photo.</div>

          <div class="d-flex flex-wrap gap-2 mt-3">
            <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
            <span class="chip"><i class="bi bi-kanban"></i> Chantier</span>
            <span class="chip chip--pill">
              <i class="bi bi-pencil-square"></i> {{ modeEdition ? 'Modification' : 'Création' }}
            </span>
            {% if chantier.id %}
              <span class="chip"><i class="bi bi-hash"></i> #{{ chantier.id }}</span>
            {% endif %}
          </div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
          <a class="btn btn-outline-theme btn-sm fw-semibold"
             href="{{ path('app_administrateur_chantier_index', {entite: entite.id}) }}">
            <i class="bi bi-arrow-left me-1"></i> Retour
          </a>

          <button form="{{ form.vars.id }}" type="submit" class="btn btn-light btn-sm fw-semibold" id="btnHeroSubmit">
            <i class="bi bi-check2 me-1"></i> Enregistrer
          </button>
        </div>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  {{ form_start(form, {
    attr: {
      id: form.vars.id,
      novalidate: 'novalidate',
      name: 'chantier_administrateur'
    }
  }) }}
  {{ form_errors(form) }}

  <div class="row g-4">
    <div class="col-lg-8">

      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-info-circle text-warning"></i> Informations générales</h5>
          <span class="chip">Étape 1</span>
        </div>

        <div class="p-3 p-md-4">
          <div class="row g-3">
            <div class="col-md-6">{{ form_row(form.nom) }}</div>
            <div class="col-md-6">{{ form_row(form.statut) }}</div>

            <div class="col-md-6">{{ form_row(form.adresse) }}</div>
            <div class="col-md-6">{{ form_row(form.complement) }}</div>

            <div class="col-md-4">{{ form_row(form.codePostal) }}</div>
            <div class="col-md-8">{{ form_row(form.ville) }}</div>

            <div class="col-12">{{ form_row(form.naturePrestation) }}</div>
          </div>
        </div>
      </div>

      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-calendar3 text-warning"></i> Intervention</h5>
          <span class="chip">Étape 2</span>
        </div>

        <div class="p-3 p-md-4">
          <div class="row g-3">
            <div class="col-md-6">{{ form_row(form.dateDebutPrevisionnelle) }}</div>
            <div class="col-md-6">{{ form_row(form.dateFinPrevisionnelle) }}</div>

            <div class="col-md-6">{{ form_row(form.dateDebutReelle) }}</div>
            <div class="col-md-6">{{ form_row(form.dateFinReelle) }}</div>

            <div class="col-md-6">{{ form_row(form.surfaceTraitee) }}</div>
            <div class="col-md-6">{{ form_row(form.lineaireTraite) }}</div>

            <div class="col-12">{{ form_row(form.difficultesRencontrees) }}</div>
          </div>
        </div>
      </div>

      {% for fieldName, meta in collections %}
        <div class="cardx mb-4">
          <div class="cardx-h">
            <div class="d-flex align-items-center gap-2 flex-wrap">
              <h5 class="cardx-title mb-0">
                <i class="bi {{ meta.icon }} text-warning"></i> {{ meta.label }}
              </h5>
              <span class="chip">{{ meta.chip }}</span>
            </div>

            <div class="d-flex align-items-center gap-2">
              <button type="button"
                      class="btn btn-warning btn-sm add-collection-item"
                      data-collection-holder="#{{ fieldName }}-holder">
                <i class="bi bi-plus-circle me-1"></i> {{ meta.btn }}
              </button>

              {% if meta.quick is defined %}
                <button type="button"
                        class="btn btn-outline-warning btn-sm rounded-circle js-open-quick-resource"
                        data-kind="{{ meta.quick }}"
                        title="Créer une ressource à la volée">
                  <i class="bi bi-plus-lg"></i>
                </button>
              {% endif %}
            </div>
          </div>

          <div class="p-3 p-md-4">
            <div id="{{ fieldName }}-holder"
                 class="collection-holder"
                 data-index="{{ attribute(form, fieldName)|length }}"
                 data-prototype="{% if fieldName == 'photos' %}{{ include('administrateur/chantier/_photo_item.html.twig', { row: attribute(form, fieldName).vars.prototype })|e('html_attr') }}{% else %}{{ form_widget(attribute(form, fieldName).vars.prototype)|e('html_attr') }}{% endif %}">
              {% for row in attribute(form, fieldName) %}
                <div class="collection-item">
                  <button type="button" class="btn btn-outline-danger btn-sm remove-collection-item">
                    <i class="bi bi-trash"></i>
                  </button>
                  {% if fieldName == 'photos' %}
                    {% include 'administrateur/chantier/_photo_item.html.twig' with { row: row } %}
                  {% else %}
                    {{ form_widget(row) }}
                  {% endif %}
                </div>
              {% else %}
                <div class="collection-empty empty-placeholder">
                  <i class="bi bi-inbox me-1"></i> Aucun élément ajouté pour le moment.
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
      {% endfor %}

      <div class="d-flex justify-content-end gap-2 mt-3 mb-3">
        <a href="{{ path('app_administrateur_chantier_index', {entite: entite.id}) }}" class="btn btn-secondary">
          <i class="bi bi-arrow-left"></i> Retour
        </a>
        <button type="submit" class="btn btn-gradient" id="btnBottomSubmit">
          <i class="bi bi-check2"></i> {{ modeEdition ? 'Modifier' : 'Créer & terminer' }}
        </button>
      </div>
    </div>

    <div class="col-lg-4">

      <div class="cardx mb-4">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-clipboard2-check text-warning"></i> Résumé</h5>
          <span class="chip">Contrôle</span>
        </div>

        <div class="p-3 p-md-4">
          <div class="small text-muted mb-3">Vérifie les informations essentielles avant enregistrement.</div>

          <div class="resume-box mb-3">
            <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap mb-2">
              <div class="fw-bold">Chantier</div>
              <span id="resume-valid-pill" class="resume-pill">⚠️ Incomplet</span>
            </div>

            <div class="resume-line">
              <span class="text-muted">Nom</span>
              <span class="fw-semibold text-end" id="resume-nom">{{ chantier.nom ?: '-' }}</span>
            </div>
            <div class="resume-line">
              <span class="text-muted">Statut</span>
              <span class="fw-semibold text-end" id="resume-statut">
                {{ chantier.statut ? chantier.statut.label() : '-' }}
              </span>
            </div>
            <div class="resume-line">
              <span class="text-muted">Ville</span>
              <span class="fw-semibold text-end" id="resume-ville">{{ chantier.ville ?: '-' }}</span>
            </div>
            <div class="resume-line">
              <span class="text-muted">Zones</span>
              <span class="fw-semibold text-end" id="resume-zones">{{ chantier.zones|length }}</span>
            </div>
            <div class="resume-line">
              <span class="text-muted">Ressources humaines</span>
              <span class="fw-semibold text-end" id="resume-rh">{{ chantier.ressourcesHumaines|length }}</span>
            </div>
            <div class="resume-line">
              <span class="text-muted">Engins</span>
              <span class="fw-semibold text-end" id="resume-engins">{{ chantier.ressourcesEngins|length }}</span>
            </div>
            <div class="resume-line">
              <span class="text-muted">Matériel</span>
              <span class="fw-semibold text-end" id="resume-materiels">{{ chantier.ressourcesMateriels|length }}</span>
            </div>
            <div class="resume-line">
              <span class="text-muted">Déchets</span>
              <span class="fw-semibold text-end" id="resume-dechets">{{ chantier.dechets|length }}</span>
            </div>
            <div class="resume-line">
              <span class="text-muted">Photos</span>
              <span class="fw-semibold text-end" id="resume-photos">{{ chantier.photos|length }}</span>
