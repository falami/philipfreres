{% extends 'base_admin.html.twig' %}

{% block title %}Matériel #{{ materiel.id }} - {{ materiel.nom }}{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('dist/css/style.css') }}">

  <style>
    :root{
      --theme-color-principal: {{ themeColorPrimaire|default(entite.couleurPrincipal|default('#233342')) }};
      --theme-color-secondaire: {{ themeColorSecondaire|default(entite.couleurSecondaire|default('#ffc107')) }};
      --stroke: rgba(15,23,42,.10);
      --radius: 18px;
    }

    .hero{
      border-radius:22px;
      position:relative;
      overflow:hidden;
      color:#fff;
      box-shadow:0 18px 50px rgba(0,0,0,.14);
      background:
        radial-gradient(900px 380px at 92% 0%, color-mix(in srgb, var(--theme-color-secondaire) 32%, transparent), transparent 60%),
        linear-gradient(135deg, color-mix(in srgb, var(--theme-color-principal) 92%, #000 8%), color-mix(in srgb, var(--theme-color-principal) 70%, #fff 30%));
    }
    .chip{
      display:inline-flex;align-items:center;gap:.45rem;padding:.28rem .65rem;border-radius:999px;font-size:.82rem;
      background:rgba(255,255,255,.10);border:1px solid rgba(255,255,255,.14);color:rgba(255,255,255,.92);
    }
    .cardx{
      background:#fff;border:1px solid var(--stroke);border-radius:var(--radius);
      box-shadow:0 10px 28px rgba(15,23,42,.08);overflow:hidden;
    }
    .cardx-h{
      padding:.95rem 1.05rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;
      background:linear-gradient(180deg,rgba(0,0,0,.015),transparent);border-bottom:1px solid var(--stroke);
    }
    .cardx-title{margin:0;font-weight:800;letter-spacing:-.01em;display:flex;align-items:center;gap:.6rem}
    .thumb-big{
      width:120px;height:120px;border-radius:22px;overflow:hidden;flex:0 0 auto;
      border:1px solid rgba(255,255,255,.28);background:rgba(255,255,255,.12);display:grid;place-items:center;
    }
    .thumb-big img{width:100%;height:100%;object-fit:cover}
  </style>
{% endblock %}

{% block body %}
  <div class="hero p-3 mb-4 d-flex gap-3 align-items-center">
    <div class="thumb-big">
      {% if materiel.photoCouverture %}
        <img src="{{ asset('uploads/photos/materiel/' ~ materiel.photoCouverture) }}" alt="{{ materiel.nom }}">
      {% else %}
        <i class="bi bi-image fs-1"></i>
      {% endif %}
    </div>

    <div class="flex-grow-1">
      <div class="d-flex justify-content-between gap-3 flex-wrap">
        <div>
          <h2 class="m-0 fw-bold">
            <i class="bi bi-tools me-2" style="color:var(--theme-color-secondaire)"></i>
            {{ materiel.nom }}
          </h2>

          <div class="d-flex gap-2 flex-wrap mt-3">
            <span class="chip"><i class="bi bi-building"></i> {{ entite.nom }}</span>
            <span class="chip"><i class="bi bi-hash"></i> #{{ materiel.id }}</span>
            <span class="chip"><i class="bi bi-diagram-3"></i> {{ materiel.categorie ? materiel.categorie.label : 'Sans catégorie' }}</span>
            <span class="chip">
              <i class="bi bi-shield-check"></i> {{ materiel.statut.label }}
            </span>
          </div>
        </div>

        <div class="d-flex gap-2 align-items-start">
          <a href="{{ path('app_administrateur_materiel_index',{entite:entite.id}) }}" class="btn btn-outline-light btn-sm fw-semibold">
            <i class="bi bi-arrow-left me-1"></i> Retour
          </a>
          <a href="{{ path('app_administrateur_materiel_modifier',{entite:entite.id,id:materiel.id}) }}" class="btn btn-light btn-sm fw-semibold">
            <i class="bi bi-pencil me-1"></i> Modifier
          </a>
          <form method="post"
                action="{{ path('app_administrateur_materiel_supprimer',{entite:entite.id,id:materiel.id}) }}"
                onsubmit="return confirm('Supprimer ce matériel ?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete_materiel_' ~ materiel.id) }}">
            <button class="btn btn-danger btn-sm fw-semibold" type="submit">
              <i class="bi bi-trash me-1"></i> Supprimer
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  {% include 'flagMessage.html.twig' %}

  <div class="row g-4">
    <div class="col-lg-7">
      <div class="cardx">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-info-circle text-warning"></i> Informations</h5>
        </div>

        <div class="p-3 p-md-4">
          <div class="row g-3">
            <div class="col-md-6">
              <div class="text-muted small">Nom</div>
              <div class="fw-semibold">{{ materiel.nom ?: '-' }}</div>
            </div>

            <div class="col-md-6">
              <div class="text-muted small">Catégorie</div>
              <div class="fw-semibold">{{ materiel.categorie ? materiel.categorie.label : '-' }}</div>
            </div>

            <div class="col-md-6">
              <div class="text-muted small">Numéro de série</div>
              <div class="fw-semibold">{{ materiel.numeroSerie ?: '-' }}</div>
            </div>

            <div class="col-md-6">
              <div class="text-muted small">Statut</div>
              <div class="fw-semibold">
                <span class="badge {{ materiel.statut.badgeClass }}">
                  {{ materiel.statut.label }}
                </span>
              </div>
            </div>

            <div class="col-md-6">
              <div class="text-muted small">Date de création</div>
              <div class="fw-semibold">
                {{ materiel.dateCreation ? materiel.dateCreation|date('d/m/Y H:i') : '-' }}
              </div>
            </div>

            <div class="col-12">
              <div class="text-muted small">Créé par</div>
              <div class="fw-semibold">
                {% if materiel.createur %}
                  {{ materiel.createur.prenom ?? '' }} {{ materiel.createur.nom ? materiel.createur.nom|upper : '' }}
                {% else %}
                  -
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="cardx">
        <div class="cardx-h">
          <h5 class="cardx-title"><i class="bi bi-image text-warning"></i> Visuel</h5>
        </div>

        <div class="p-3 p-md-4 text-center">
          {% if materiel.photoCouverture %}
            <img src="{{ asset('uploads/photos/materiel/' ~ materiel.photoCouverture) }}"
                 alt="{{ materiel.nom }}"
                 class="img-fluid rounded-4 border">
          {% else %}
            <div class="text-muted">Aucune photo de couverture.</div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
{% endblock %}