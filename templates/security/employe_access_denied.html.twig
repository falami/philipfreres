{% extends 'base.html.twig' %}

{% block title %}Accès restreint{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
<style>
    body {
        background-color: #0f1b28 !important;
        color: white;
    }
</style>
{% endblock %}

{% block body %}
<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg p-4 text-center" style="max-width: 480px; width: 100%;">


        <div class="text-center">
            <img class="mb-3 rounded" src="{{ asset('uploads/photos/entite/logo/logo-philip-freres.jpg') }}" alt="Logo" style="width: 100px;">
        </div>
        <div class="mb-3">
            <i class="bi bi-shield-lock-fill display-3 text-warning"></i>
        </div>

        <h4 class="mb-3">Accès non autorisé</h4>

        <p class="text-muted">
            Votre compte est enregistré comme <strong>Employé</strong>.
        </p>

        <p class="text-muted">
            L'accès à cette plateforme est actuellement restreint.
        </p>

        <hr class="my-4">

        <p class="small text-muted">
            Si vous pensez qu'il s'agit d'une erreur, veuillez contacter l'administrateur du site.
        </p>

        <div class="d-flex justify-content-center gap-3 mt-3 flex-wrap">
            <a href="{{ path('app_logout') }}" class="btn btn-primary">
                <i class="bi bi-box-arrow-in-right"></i> Se déconnecter
            </a>

            <a href="mailto:contact@philippfreres.fr" class="btn btn-outline-secondary">
                <i class="bi bi-envelope"></i> Contacter l’administrateur
            </a>
        </div>

    </div>
</div>
{% endblock %}