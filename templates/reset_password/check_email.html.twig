{% extends 'base.html.twig' %}

{% block title %}Email envoyé{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
<style>
    body {
        background-color: #0f1b28;
        color: white;
    }
</style>
{% endblock %}

{% block body %}
<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg p-4 text-center" style="max-width: 420px; width: 100%;">
        
        <div class="mb-3">
            <i class="bi bi-envelope-check display-4 text-success"></i>
        </div>

        <h5>Email envoyé</h5>

        <p class="text-muted mt-3">
            Si un compte correspond à votre email,
            un lien de réinitialisation vous a été envoyé.
        </p>

        <p class="text-muted">
            Ce lien est valide <strong>{{ ttlHuman|default('1 heure') }}</strong>.
        </p>

        <div class="d-flex justify-content-center gap-2 mt-4 flex-wrap">
            <a href="{{ path('app_forgot_password_request') }}" class="btn btn-warning">
                <i class="bi bi-arrow-clockwise"></i> Réessayer
            </a>

            <a href="{{ path('app_login') }}" class="btn btn-primary">
                <i class="bi bi-box-arrow-in-right"></i> Connexion
            </a>
        </div>
    </div>
</div>
{% endblock %}