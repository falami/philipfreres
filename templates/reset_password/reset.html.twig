{% extends 'base.html.twig' %}

{% block title %}Réinitialiser le mot de passe{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
<style>
    body {
        background-color: #0f1b28 !important;
        color: white;
    }
</style>
{% endblock %}

{% block body %}
<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg p-4" style="max-width: 400px; width: 100%;">

        <div class="text-center">
            <img class="mb-3 rounded"
                 src="{{ asset('uploads/photos/entite/logo/logo-philip-freres.jpg') }}"
                 alt="Logo"
                 style="width: 100px;">
        </div>

        <h5 class="text-center mb-3">Nouveau mot de passe</h5>

        {% if expiresAt is defined %}
            <p class="text-center text-muted small">
                Lien valide jusqu’au
                <strong>{{ expiresAt|date('d/m/Y H:i') }}</strong>
            </p>
        {% endif %}

        {% include 'flagMessage.html.twig' %}

        {{ form_start(resetForm) }}

            <div class="mb-3">
                <label class="form-label">Nouveau mot de passe</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-lock"></i>
                    </span>

                    {{ form_widget(resetForm.password.first, {
                        attr: {
                            class: 'form-control',
                            placeholder: 'Entrez votre nouveau mot de passe'
                        }
                    }) }}
                </div>
                {{ form_errors(resetForm.password.first) }}
            </div>

            <div class="mb-3">
                <label class="form-label">Confirmer le mot de passe</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-shield-lock"></i>
                    </span>

                    {{ form_widget(resetForm.password.second, {
                        attr: {
                            class: 'form-control',
                            placeholder: 'Confirmez votre mot de passe'
                        }
                    }) }}
                </div>
                {{ form_errors(resetForm.password.second) }}
            </div>

            <button class="btn btn-primary w-100" type="submit">
                <i class="bi bi-check-circle"></i>
                Mettre à jour
            </button>

            <div class="text-center mt-3">
                <small>
                    <a href="{{ path('app_login') }}" class="text-muted">
                        <i class="bi bi-arrow-left"></i> Retour à la connexion
                    </a>
                </small>
            </div>

        {{ form_end(resetForm) }}

    </div>
</div>
{% endblock %}